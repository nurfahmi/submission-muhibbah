<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || (typeof siteSettings !== 'undefined' && siteSettings.site_name) || 'Credit Submission System' %></title>
  <% if (typeof siteSettings !== 'undefined' && siteSettings.favicon_url) { %>
    <link rel="icon" href="<%= siteSettings.favicon_url %>" type="image/x-icon">
  <% } %>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: { 50:'#f0f9ff',100:'#e0f2fe',200:'#bae6fd',300:'#7dd3fc',400:'#38bdf8',500:'#0ea5e9',600:'#0284c7',700:'#0369a1',800:'#075985',900:'#0c4a6e' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen">
  <% if (typeof user !== 'undefined' && user) { %>
    <div class="flex min-h-screen">
      <%- include('../partials/sidebar') %>
      <div class="flex-1 flex flex-col min-w-0">
        <%- include('../partials/header') %>
        <main class="flex-1 p-4 sm:p-6 overflow-x-hidden">
          <%- body %>
        </main>
      </div>
    </div>
  <% } else { %>
    <main class="min-h-screen flex items-center justify-center">
      <%- body %>
    </main>
  <% } %>

  <script>
    function toggleDark() {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    }
    if (localStorage.getItem('theme') === 'light') {
      document.documentElement.classList.remove('dark');
    }
  </script>

  <% if (typeof user !== 'undefined' && user && (user.role === 'superadmin' || user.role === 'admin')) { %>
  <!-- Admin Notification System -->
  <div id="notifToast" class="fixed top-4 right-4 z-[100] hidden">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 p-4 flex items-center gap-3 min-w-[300px] animate-[slideIn_0.3s_ease-out]">
      <div class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">Kes Baru!</p>
        <p id="notifMsg" class="text-xs text-gray-500 dark:text-gray-400"></p>
      </div>
      <button onclick="document.getElementById('notifToast').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
  <style>
    @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  </style>
  <script>
  (function() {
    // Track notified case IDs to avoid duplicate alerts
    function getNotified() {
      try { return JSON.parse(sessionStorage.getItem('notifiedCases') || '[]'); } catch { return []; }
    }
    function addNotified(id) {
      const list = getNotified();
      if (!list.includes(id)) {
        list.push(id);
        // Keep only last 100
        if (list.length > 100) list.splice(0, list.length - 100);
        sessionStorage.setItem('notifiedCases', JSON.stringify(list));
      }
    }
    function isNotified(id) {
      return getNotified().includes(id);
    }

    function playNotifSound() {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const notes = [660, 880, 1100];
        notes.forEach((freq, i) => {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.frequency.value = freq;
          osc.type = 'sine';
          gain.gain.setValueAtTime(0.15, ctx.currentTime + i * 0.15);
          gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.15 + 0.3);
          osc.start(ctx.currentTime + i * 0.15);
          osc.stop(ctx.currentTime + i * 0.15 + 0.3);
        });
      } catch(e) {}
    }

    function showToast(name) {
      const toast = document.getElementById('notifToast');
      const msg = document.getElementById('notifMsg');
      msg.textContent = 'Permohonan baru dari ' + name;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 8000);
    }

    function connectWs() {
      const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
      const ws = new WebSocket(proto + '//' + location.host + '/ws/notifications');

      ws.onmessage = function(event) {
        try {
          const data = JSON.parse(event.data);
          if (data.type === 'NEW_CASE' && !isNotified(data.caseId)) {
            addNotified(data.caseId);
            playNotifSound();
            showToast(data.applicantName);
          }
        } catch(e) {}
      };

      ws.onclose = function() {
        // Reconnect after 5 seconds
        setTimeout(connectWs, 5000);
      };

      ws.onerror = function() {
        ws.close();
      };
    }

    connectWs();
  })();
  </script>
  <% } %>
</body>
</html>
