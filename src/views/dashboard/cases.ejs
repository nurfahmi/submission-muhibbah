<%
  const productMap = {};
  if (typeof loanProducts !== 'undefined') {
    loanProducts.forEach(p => {
      productMap[p.key] = p.label;
      if (p.children) p.children.forEach(c => { productMap[c.key] = p.label; });
    });
  }
  function getProductName(key) { return key ? (productMap[key] || key) : '-'; }
%>
<div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800">
  <div class="px-4 sm:px-6 py-4 border-b border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
    <div class="flex items-center gap-2">
      <h3 class="text-base font-semibold">Pending Cases</h3>
      <span class="text-xs text-gray-400">Oldest → Newest</span>
    </div>
    <div class="relative w-full sm:w-72">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" id="caseSearch" placeholder="Cari nama, IC..."
        class="w-full pl-9 pr-4 py-2 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
    </div>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 dark:border-gray-800">
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Customer Name</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Customer IC</th>
          <% if (user.role === 'superadmin' || user.role === 'admin') { %>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Master Agent</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Sub Agent</th>
          <% } else if (user.role === 'masteragent') { %>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Agent</th>
          <% } %>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Product</th>
          <% if (user.role === 'superadmin' || user.role === 'admin') { %>
          <th class="text-center px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Action</th>
          <% } else { %>
          <th class="text-center px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Status</th>
          <% } %>
        </tr>
      </thead>
      <tbody id="caseTableBody">
        <% const colCount = (user.role === 'superadmin' || user.role === 'admin') ? 6 : (user.role === 'masteragent' ? 5 : 4); %>
        <% if (submissions.length === 0) { %>
          <tr><td colspan="<%= colCount %>" class="px-3 sm:px-6 py-8 text-center text-gray-400">No pending cases</td></tr>
        <% } %>
        <% submissions.forEach(s => { %>
          <tr class="case-row border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
            data-name="<%= (s.applicant_name || '').toLowerCase() %>"
            data-ic="<%= (s.applicant_ic || '').toLowerCase() %>">
            <td class="px-3 sm:px-6 py-3 font-medium">
              <div class="flex items-center gap-2">
                <%= s.applicant_name %>
                <% if (s.needs_image_review) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300" title="Gambar perlu disemak">📷</span>
                <% } %>
              </div>
              <div class="text-xs text-gray-400 sm:hidden"><%= s.applicant_ic !== '-' ? s.applicant_ic : '' %></div>
            </td>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell font-mono text-xs"><%= s.applicant_ic %></td>
            <% if (user.role === 'superadmin' || user.role === 'admin') { %>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= s.masteragent_name %></td>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= s.subagent_name %></td>
            <% } else if (user.role === 'masteragent') { %>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= s.subagent_name %></td>
            <% } %>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell text-xs"><%= getProductName(s.product_key) %></td>
            <td class="px-3 sm:px-6 py-3 text-center">
              <% if (user.role === 'superadmin' || user.role === 'admin') { %>
                <div class="flex items-center justify-center gap-1.5">
                  <a href="/dashboard/cases/<%= s.id %>" class="px-2.5 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">View</a>
                  <form method="POST" action="/dashboard/cases/<%= s.id %>/take" class="inline">
                    <button type="submit" class="px-2.5 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-lg text-xs font-medium hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors">Take</button>
                  </form>
                </div>
              <% } else { %>
                <div class="flex items-center justify-center gap-1.5">
                  <a href="/dashboard/cases/<%= s.id %>" class="px-2.5 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">View</a>
                  <% if (s.taken_by) { %>
                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300">Diambil</span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300">Belum Diambil</span>
                  <% } %>
                </div>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { tableId: 'caseTableBody', perPage: 10, rowClass: 'case-row' }) %>
  <div id="noResults" class="hidden px-4 sm:px-6 py-8 text-center text-gray-400 text-sm">Tiada hasil carian ditemui</div>
</div>

<script>
(function() {
  const searchInput = document.getElementById('caseSearch');
  const rows = document.querySelectorAll('.case-row');
  const noResults = document.getElementById('noResults');
  if (searchInput && rows.length > 0) {
    searchInput.addEventListener('input', function() {
      const q = this.value.toLowerCase().trim();
      let visible = 0;
      document.querySelectorAll('.case-row').forEach(row => {
        const name = row.dataset.name || '';
        const ic = row.dataset.ic || '';
        const match = !q || name.includes(q) || ic.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    });
  }
})();
</script>

<% if (typeof user !== 'undefined' && user && (user.role === 'superadmin' || user.role === 'admin')) { %>
<style>
  @keyframes highlightRow { from { background: rgba(14,165,233,0.15); } to { background: transparent; } }
</style>
<script>
(function() {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  let ws;
  const colCount = <%= (user.role === 'superadmin' || user.role === 'admin') ? 4 : 3 %>;

  function connect() {
    ws = new WebSocket(proto + '//' + location.host + '/ws/notifications');
    ws.onmessage = function(event) {
      try {
        const data = JSON.parse(event.data);
        if (data.type === 'NEW_CASE') addCaseRow(data);
        else if (data.type === 'CASE_TAKEN') markCaseTaken(data);
      } catch(e) {}
    };
    ws.onclose = function() { setTimeout(connect, 5000); };
    ws.onerror = function() { ws.close(); };
  }

  function addCaseRow(data) {
    const tbody = document.getElementById('caseTableBody');
    if (!tbody) return;
    const emptyRow = tbody.querySelector('td[colspan]');
    if (emptyRow) emptyRow.closest('tr').remove();

    const tr = document.createElement('tr');
    tr.className = 'case-row border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors';
    tr.dataset.name = (data.applicantName || '').toLowerCase();
    tr.dataset.caseId = data.caseId;
    tr.style.animation = 'highlightRow 3s ease-out';
    tr.innerHTML = `
      <td class="px-3 sm:px-6 py-3 font-medium"><div>${data.applicantName}</div></td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell font-mono text-xs">-</td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell">${data.agentName || '-'}</td>
      <td class="px-3 sm:px-6 py-3 text-center">
        <form method="POST" action="/dashboard/cases/${data.caseId}/take" class="inline">
          <button type="submit" class="px-3 py-1.5 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-xs font-medium transition-colors">Ambil Kes</button>
        </form>
      </td>`;
    tbody.appendChild(tr);
  }

  function markCaseTaken(data) {
    const tbody = document.getElementById('caseTableBody');
    if (!tbody) return;
    // Remove the taken case row
    let row = tbody.querySelector('tr[data-case-id="' + data.caseId + '"]');
    if (!row) {
      const form = tbody.querySelector('form[action="/dashboard/cases/' + data.caseId + '/take"]');
      if (form) row = form.closest('tr');
    }
    if (row) {
      row.style.animation = 'highlightRow 0.5s ease-out';
      setTimeout(() => row.remove(), 500);
      // Show empty message if no rows left
      setTimeout(() => {
        if (!tbody.querySelector('.case-row')) {
          const tr = document.createElement('tr');
          const colCount = <%= (user.role === 'superadmin' || user.role === 'admin') ? 4 : 3 %>;
          tr.innerHTML = '<td colspan="' + colCount + '" class="px-3 sm:px-6 py-8 text-center text-gray-400">No pending cases</td>';
          tbody.appendChild(tr);
        }
      }, 600);
    }
  }

  connect();
})();
</script>
<% } %>
<%- include('../partials/pagination-script') %>
