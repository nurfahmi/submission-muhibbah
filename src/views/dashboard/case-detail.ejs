        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">File</label>
        <input type="file" name="file" required
          class="w-full text-sm text-gray-600 dark:text-gray-400 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-primary-100 dark:file:bg-primary-900/30 file:text-primary-700 dark:file:text-primary-300 hover:file:bg-primary-200 file:cursor-pointer file:transition-colors">
      </div>
      <button type="submit" class="shrink-0 px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm font-medium transition-colors">Upload</button>
    </form>

    <!-- File List -->
    <% if (typeof adminFiles !== 'undefined' && adminFiles.length > 0) { %>
      <div class="space-y-2">
        <% adminFiles.forEach(af => { %>
          <div class="flex items-center justify-between p-3 border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-8 h-8 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-medium truncate"><%= af.label %></p>
                <p class="text-[10px] text-gray-400 truncate"><%= af.original_name %> · <%= new Date(af.uploaded_at).toLocaleDateString('ms-MY') %></p>
              </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a href="/dashboard/admin-files/<%= af.id %>/view" target="_blank" class="px-2.5 py-1 text-xs font-medium bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400 rounded-lg hover:bg-green-100 transition-colors">View</a>
              <a href="/dashboard/admin-files/<%= af.id %>/download" class="px-2.5 py-1 text-xs font-medium bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 rounded-lg hover:bg-primary-100 transition-colors">Download</a>
              <form method="POST" action="/dashboard/cases/<%= submission.id %>/admin-files/<%= af.id %>/delete" class="inline" onsubmit="return confirm('Delete this file?')">
                <button type="submit" class="px-2.5 py-1 text-xs font-medium bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-100 transition-colors">Delete</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-sm text-gray-400 text-center py-3">No additional files attached</p>
    <% } %>
  </div>
  <% } %>

</div>

<script>
var _subData = {
  a: <%- JSON.stringify(submission.applicant_data || {}) %>,
  s: <%- JSON.stringify(submission.spouse_data || {}) %>,
  j: <%- JSON.stringify(submission.job_data || {}) %>,
  r: <%- JSON.stringify(submission.reference_data || {}) %>
};

function copyVal(btn, text) {
  navigator.clipboard.writeText(text).then(() => {
    const svg = btn.innerHTML;
    btn.innerHTML = '<svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
    setTimeout(() => { btn.innerHTML = svg; }, 1000);
  });
}

document.getElementById('btnCopyAll').addEventListener('click', function() {
  const a = _subData.a, s = _subData.s, j = _subData.j, r = _subData.r;
  const v = (val) => (val && String(val).trim()) ? String(val).trim() : '';

  const text = `PEGAWAI YANG LAYAK SIGN BPA :


1)MAKLUMAT PEMOHON :-
➜ NAMA: ${v(a.name)}
➜ KAD PENGENALAN: ${v(a.ic)}
➜ ALAMAT TETAP: ${v(a.address)}
➜ NO TEL HP: ${v(a.phone)}
➜ WARGANEGARA: MALAYSIA
➜ TARAF PERKAHWINAN : ${v(a.taraf_perkahwinan)}
➜ BILANGAN TANGGUNGAN (ANAK): ${v(a.tanggungan)}
➜ BANGSA / AGAMA : ${v(a.bangsa_agama)}
➜ TARAF PENDIDIKAN PALING TINGGI: ${v(a.pendidikan)}
➜ JENIS KEDIAMAN(MENYEWA/MILIK SENDIRI/MAJIKAN/IBUBAPA): ${v(a.jenis_kediaman)}
➜ TEMPOH MENETAP: ${v(a.tempoh_menetap)}
➜ ALAMAT EMAIL: ${v(a.email)}
➜ NAMA IBU: ${v(a.nama_ibu)}
➜ NO TEL: ${v(a.hp_ibu)}
➜ NO IC: ${v(a.ic_ibu)}

2)MAKLUMAT PASANGAN / IBU BAPA :-
➜ NAMA: ${v(s.name)}
➜ NO IC : ${v(s.ic)}
➜ TEL BIMBIT: ${v(s.phone)}
➜ HUBUNGAN: ${v(s.hubungan)}

3)MAKLUMAT PEKERJAAN PEMOHON:-
➜ NAMA MAJIKAN: ${v(j.employer)}
➜ ALAMAT MAJIKAN: ${v(j.alamat_majikan)}
➜ NO TEL PEJBT: ${v(j.tel_pejabat)}
➜ JAWATAN: ${v(j.position)}
➜ TARIKH LANTIKAN: ${v(j.tarikh_mula)}
➜ OPSYEN PENCEN : ${v(j.opsyen_pencen)}
➜ STATUS JAWATAN(TETAP/KONTRAK): ${v(j.status_jawatan)}


4)RUJUKAN SAUDARA TERDEKAT:-
➜ NAMA: ${v(r.name)}
➜ IC NO: ${v(r.ic)}
➜ NO TELEFON: ${v(r.phone)}
➜ ALAMAT: ${v(r.address)}
➜ PERTALIAN: ${v(r.relationship)}`;

  navigator.clipboard.writeText(text).then(() => {
    const label = document.getElementById('copyAllLabel');
    label.textContent = 'Copied!';
    setTimeout(() => { label.textContent = 'Copy All'; }, 1500);
  });
});
</script>
