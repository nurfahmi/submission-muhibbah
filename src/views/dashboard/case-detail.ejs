    <script>
    (function() {
      const sel = document.getElementById('uploadFileType');
      const inp = document.getElementById('uploadFileInput');
      if (!sel || !inp) return;
      function toggle() {
        if (sel.value === 'other_doc') {
          inp.setAttribute('multiple', '');
          inp.removeAttribute('accept');
        } else {
          inp.removeAttribute('multiple');
          inp.setAttribute('accept', '.jpg,.jpeg,.png,.pdf');
        }
        inp.value = '';
      }
      sel.addEventListener('change', toggle);
      toggle();
    })();
    </script>
    <% } %>
