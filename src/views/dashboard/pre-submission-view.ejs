<%
  const productMap = {};
  if (typeof loanProducts !== 'undefined' && loanProducts) {
    loanProducts.forEach(p => {
      productMap[p.key] = p.label;
      if (p.children) p.children.forEach(c => { productMap[c.key] = p.label; });
    });
  }
%>

<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <div class="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-sm px-4 py-3 rounded-xl mb-6"><%= success %></div>
<% } %>

<div class="max-w-3xl mx-auto">
  <div class="mb-4 flex items-center justify-between">
    <a href="/dashboard/pre-submissions" class="text-primary-600 dark:text-primary-400 hover:underline text-sm">← Back to List</a>
    <a href="/dashboard/pre-submissions/<%= item.id %>/edit" class="text-sm text-gray-500 hover:text-primary-500 flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Edit
    </a>
  </div>

  <!-- Customer Info -->
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6 mb-6">
    <h3 class="text-base font-semibold mb-4">Customer Details</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400">Customer Name</span>
        <p class="font-medium text-gray-900 dark:text-gray-100 mt-0.5"><%= item.customer_name || '-' %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400">IC Number</span>
        <p class="font-medium font-mono text-gray-900 dark:text-gray-100 mt-0.5"><%= item.ic_number || '-' %></p>
      </div>
      <% if (item.ic_number && item.ic_number.replace(/[-\s]/g, '').length >= 12) {
        const digits = item.ic_number.replace(/[-\s]/g, '');
        const yy = parseInt(digits.substring(0, 2));
        const mm = digits.substring(2, 4);
        const dd = digits.substring(4, 6);
        const year = yy <= 29 ? 2000 + yy : 1900 + yy;
        const lastDigit = parseInt(digits[digits.length - 1]);
        const gender = lastDigit % 2 === 1 ? 'Lelaki' : 'Perempuan';
        const dob = dd + '/' + mm + '/' + year;
        const birthDate = new Date(year, parseInt(mm) - 1, parseInt(dd));
        const today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        const m = today.getMonth() - birthDate.getMonth();
        if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) age--;
      %>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400">Date of Birth</span>
        <p class="font-medium text-gray-900 dark:text-gray-100 mt-0.5"><%= dob %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400">Age / Gender</span>
        <p class="font-medium text-gray-900 dark:text-gray-100 mt-0.5"><%= age %> years · <%= gender %></p>
      </div>
      <% } %>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400">Created By</span>
        <p class="font-medium text-gray-900 dark:text-gray-100 mt-0.5"><%= item.creator ? item.creator.username : '-' %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400">Date</span>
        <p class="font-medium text-gray-900 dark:text-gray-100 mt-0.5"><%= new Date(item.created_at).toLocaleString('ms-MY') %></p>
      </div>
    </div>
  </div>

  <!-- Loan Product PDF Selection -->
  <% if (typeof loanProducts !== 'undefined' && loanProducts.length > 0) { %>
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6 mb-6">
    <h3 class="text-base font-semibold mb-2">📄 Loan Product Form</h3>
    <p class="text-xs text-gray-400 mb-4">Select a loan product and download the form pre-filled with customer details.</p>

    <form method="POST" action="/dashboard/pre-submissions/<%= item.id %>/update-product" class="flex items-center gap-2 mb-4">
      <select name="product_key" id="productSelect"
        class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
        <option value="">-- Select Product --</option>
        <% loanProducts.forEach(p => { %>
          <option value="<%= p.key %>" <% if (item.product_key === p.key) { %>selected<% } %>><%= p.label %></option>
        <% }) %>
      </select>
      <button type="submit" id="saveProductBtn" class="hidden shrink-0 px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white rounded-xl text-sm font-medium transition-colors">Save</button>
    </form>

    <div id="productButtons" class="space-y-3"></div>
  </div>

  <script>
  (function() {
    const products = <%- JSON.stringify(loanProducts) %>;
    const itemId = '<%= item.id %>';
    const select = document.getElementById('productSelect');
    const container = document.getElementById('productButtons');
    const originalKey = '<%= item.product_key || '' %>';
    const saveBtn = document.getElementById('saveProductBtn');

    function renderButtons(key) {
      container.innerHTML = '';
      if (!key) return;
      const product = products.find(p => p.key === key);
      if (!product) return;

      if (product.children && product.children.length > 0) {
        const wrapper = document.createElement('div');
        wrapper.className = 'border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden';
        let header = '<div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 text-sm font-semibold">' + product.label + '</div>';
        let rows = '<div class="divide-y divide-gray-100 dark:divide-gray-800">';
        product.children.forEach(c => {
          rows += '<div class="px-4 py-2.5 flex items-center justify-between">' +
            '<span class="text-sm">' + c.label + '</span>' +
            '<div class="flex items-center gap-2">' +
              '<a href="/dashboard/pre-submissions/' + itemId + '/pdf/' + c.key + '?view=1" target="_blank" class="px-3 py-1.5 text-xs font-medium bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400 rounded-lg hover:bg-emerald-100 transition-colors">View</a>' +
              '<a href="/dashboard/pre-submissions/' + itemId + '/pdf/' + c.key + '" class="px-3 py-1.5 text-xs font-medium bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 rounded-lg hover:bg-primary-100 transition-colors">Download</a>' +
            '</div></div>';
        });
        rows += '</div>';
        wrapper.innerHTML = header + rows;
        container.appendChild(wrapper);
      } else if (product.file) {
        const div = document.createElement('div');
        div.className = 'border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-2.5 flex items-center justify-between';
        div.innerHTML = '<span class="text-sm font-medium">' + product.label + '</span>' +
          '<div class="flex items-center gap-2">' +
            '<a href="/dashboard/pre-submissions/' + itemId + '/pdf/' + product.key + '?view=1" target="_blank" class="px-3 py-1.5 text-xs font-medium bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400 rounded-lg hover:bg-emerald-100 transition-colors">View</a>' +
            '<a href="/dashboard/pre-submissions/' + itemId + '/pdf/' + product.key + '" class="px-3 py-1.5 text-xs font-medium bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 rounded-lg hover:bg-primary-100 transition-colors">Download</a>' +
          '</div>';
        container.appendChild(div);
      }
    }

    select.addEventListener('change', function() {
      renderButtons(this.value);
      saveBtn.classList.toggle('hidden', this.value === originalKey);
    });

    if (select.value) renderButtons(select.value);
  })();
  </script>
  <% } %>
</div>
