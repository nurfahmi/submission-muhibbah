    <div class="flex items-center gap-2 mb-3">
      <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <h2 class="text-lg font-semibold">Auto Isi dari WhatsApp</h2>
    </div>
    <p class="text-xs text-gray-400 mb-3">Paste a WhatsApp message below, then click "Auto Fill Form" to fill in all fields automatically.</p>
    <textarea id="waMessageInput" rows="6" placeholder="Paste WhatsApp message here..." class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-green-500 font-mono"></textarea>
    <div class="flex gap-2 mt-3">
      <button type="button" id="btnAutoFill" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2.5 px-6 rounded-xl text-sm transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Auto Fill Form
      </button>
      <button type="button" id="btnClearWa" class="bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 font-semibold py-2.5 px-6 rounded-xl text-sm transition-colors">
        Clear
      </button>
    </div>
    <div id="waFillResult" class="hidden mt-3 text-sm px-4 py-3 rounded-xl"></div>
  </div>
  <form id="submitForm" method="POST" action="/dashboard/submit-new" enctype="multipart/form-data" class="space-y-6">
    <input type="hidden" name="referral_code" value="<%= ref %>">
    <% if (typeof draft !== 'undefined' && draft) { %>
      <input type="hidden" name="draft_id" value="<%= draft.id %>">
    <% } %>

    <!-- Product Selection -->
    <% if (typeof loanProducts !== 'undefined' && loanProducts.length > 0) { %>
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <h2 class="text-lg font-semibold">Produk Pinjaman</h2>
      </div>
      <select name="product_key" required
        class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
        <option value="">-- Select Product --</option>
        <% loanProducts.forEach(p => { %>
          <option value="<%= p.key %>"><%= p.label %></option>
        <% }) %>
      </select>
    </div>
    <% } %>

    <% if (typeof agents !== 'undefined' && agents.length > 0) { %>
    <!-- Agent Assignment (Admin/SuperAdmin only) -->
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        <h2 class="text-lg font-semibold">Assign Referer</h2>
      </div>
      <p class="text-xs text-gray-400 mb-3">Select the agent who referred this case. Leave empty if none.</p>
      <div class="relative">
        <input type="hidden" name="assign_agent" id="assignAgentHidden"
          value="<%= (typeof draft !== 'undefined' && draft) ? (draft.subagent_id || draft.masteragent_id || '') : '' %>">
        <div class="flex gap-2">
          <div class="relative flex-1">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" id="agentSearch" autocomplete="off" placeholder="Search agent..."
              class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
          </div>
          <button type="button" id="clearAgent" class="px-3 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 text-sm transition-colors" title="Clear">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div id="agentDropdown" class="hidden absolute z-10 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-60 overflow-y-auto">
          <% agents.forEach(ag => { %>
            <div class="agent-option px-4 py-2.5 text-sm hover:bg-primary-50 dark:hover:bg-primary-900/30 cursor-pointer transition-colors flex items-center justify-between"
              data-id="<%= ag.id %>" data-name="<%= ag.username %>" data-ref="<%= ag.referral_code || '' %>" data-role="<%= ag.role %>">
              <div>
                <span class="font-medium"><%= ag.username %></span>
                <% if (ag.referral_code) { %>
                  <span class="text-xs text-gray-400 ml-2"><%= ag.referral_code %></span>
                <% } %>
              </div>
              <span class="px-2 py-0.5 rounded text-xs font-medium
                <% if (ag.role === 'masteragent') { %>bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-300
                <% } else { %>bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400<% } %>"><%= ag.role === 'masteragent' ? 'Manager' : 'User' %></span>
            </div>
          <% }) %>
          <div id="agentNoResult" class="hidden px-4 py-3 text-sm text-gray-400 text-center">No agent found</div>
        </div>
      </div>
      <div id="selectedAgentBadge" class="hidden mt-2 inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-sm font-medium"></div>
    </div>
    <% } %>
    <% const d = (typeof draft !== 'undefined' && draft) ? draft : null; %>
    <% const a = d ? (d.applicant_data || {}) : {}; %>
    <% const sp = d ? (d.spouse_data || {}) : {}; %>
    <% const j = d ? (d.job_data || {}) : {}; %>
    <% const r = d ? (d.reference_data || {}) : {}; %>

