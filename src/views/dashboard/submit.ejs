<script>
function copyTemplate() {
  const text = document.getElementById('templateNote').textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✓ Copied!';
    btn.classList.add('bg-green-100', 'dark:bg-green-900/30', 'text-green-700', 'dark:text-green-300');
    setTimeout(() => {
      btn.textContent = 'Copy';
      btn.classList.remove('bg-green-100', 'dark:bg-green-900/30', 'text-green-700', 'dark:text-green-300');
    }, 2000);
  });
}
</script>

<script>
(function() {
  const form = document.getElementById('submitForm');
  const errorDiv = document.getElementById('fileError');
  const requiredFiles = {};
  <% const _ss2 = typeof siteSettings !== 'undefined' ? siteSettings : {};
     const _fileMap2 = {
       ic_depan: 'IC Depan', ic_belakang: 'IC Belakang',
       payslip1: 'Payslip Terkini 1', payslip2: 'Payslip Terkini 2', payslip3: 'Payslip Terkini 3',
       bank_page: 'Muka Surat Akaun Bank', signature: 'Tandatangan Customer',
       chop_sign: 'Chop & Sign Majikan', bill_rumah: 'Bill Rumah', settlement_letter: 'Settlement Letter'
     };
     Object.entries(_fileMap2).forEach(([key, label]) => {
       const settingKey = 'req_' + key;
       const isReq = _ss2[settingKey] === 'true' || (!_ss2[settingKey] && (key === 'ic_depan' || key === 'ic_belakang'));
       if (isReq) { %>
  requiredFiles['<%= key %>'] = '<%= label %>';
  <%   }
     }); %>

  form.addEventListener('submit', function(e) {
    // Skip validation for draft
    const action = e.submitter?.value;
    if (action === 'draft') return;

    const missing = [];
    for (const [name, label] of Object.entries(requiredFiles)) {
      const input = form.querySelector('input[name="' + name + '"]');
      if (!input || !input.files || input.files.length === 0) {
        missing.push(label);
      }
    }
    if (missing.length > 0) {
      e.preventDefault();
      errorDiv.innerHTML = '<strong>Please upload the required documents:</strong><br>' + missing.join(', ');
      errorDiv.classList.remove('hidden');
      errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      errorDiv.classList.add('hidden');
    }
  });
})();
</script>

