<script>
(function() {
  const btnAutoFill = document.getElementById('btnAutoFill');
  const btnClearWa = document.getElementById('btnClearWa');
  const waInput = document.getElementById('waMessageInput');
  const waResult = document.getElementById('waFillResult');

  function showResult(msg, isError) {
    waResult.classList.remove('hidden', 'bg-green-50', 'dark:bg-green-900/20', 'text-green-700', 'dark:text-green-300',
      'bg-red-50', 'dark:bg-red-900/20', 'text-red-700', 'dark:text-red-300');
    if (isError) {
      waResult.classList.add('bg-red-50', 'dark:bg-red-900/20', 'text-red-700', 'dark:text-red-300');
    } else {
      waResult.classList.add('bg-green-50', 'dark:bg-green-900/20', 'text-green-700', 'dark:text-green-300');
    }
    waResult.textContent = msg;
  }

  function setVal(name, value) {
    const el = document.querySelector('[name="' + name + '"]');
    if (!el) return false;
    value = (value || '').trim();
    if (!value) return false;
    if (el.tagName === 'SELECT') {
      const opts = el.options;
      for (let i = 0; i < opts.length; i++) {
        if (opts[i].value.toLowerCase() === value.toLowerCase()) {
          el.value = opts[i].value;
          return true;
        }
      }
      for (let i = 0; i < opts.length; i++) {
        if (opts[i].value.toLowerCase().includes(value.toLowerCase()) || value.toLowerCase().includes(opts[i].value.toLowerCase())) {
          el.value = opts[i].value;
          return true;
        }
      }
      return false;
    }
    // Email should always be lowercase
    if (name.includes('email')) value = value.toLowerCase();
    el.value = value;
    return true;
  }

  function parseWhatsApp(text) {
    const lines = text.split('\n');
    let section = 0; // 0=unknown, 1=pemohon, 2=pasangan, 3=pekerjaan, 4=rujukan
    let filled = 0;

    for (let i = 0; i < lines.length; i++) {
      let line = lines[i].trim();
      if (!line) continue;

      // Detect section headers
      const lineLower = line.toLowerCase();
      if (lineLower.includes('maklumat pemohon') && !lineLower.includes('pekerjaan')) { section = 1; continue; }
      if (lineLower.includes('maklumat pasangan') || lineLower.includes('ibu bapa')) { section = 2; continue; }
      if (lineLower.includes('maklumat pekerjaan') || lineLower.includes('pekerjaan pemohon')) { section = 3; continue; }
      if (lineLower.includes('rujukan saudara') || lineLower.includes('saudara terdekat')) { section = 4; continue; }
      if (lineLower.includes('waris berumur')) continue; // Skip instruction line
      if (lineLower.includes('doc diperlukan') || lineLower.includes('dokumen diperlukan')) { section = 5; continue; }
      if (section === 5) continue;

      // Remove emoji markers (➜, 👉, arrows)
      line = line.replace(/[➜👉→▶►]/g, '').trim();

      // Extract key:value - split on first colon
      const colonIdx = line.indexOf(':');
      if (colonIdx === -1) continue;

      const rawKey = line.substring(0, colonIdx).trim().toLowerCase();
      let value = line.substring(colonIdx + 1).trim();
      // Remove leading :- or -
      value = value.replace(/^[:\-\s]+/, '').trim();

      if (!value) continue;

      // === SECTION 1: MAKLUMAT PEMOHON ===
      // Priority: most-specific key first to avoid false matches
      // BPA order: NAMA, KAD PENGENALAN, ALAMAT TETAP, NO TEL HP, WARGANEGARA,
      //   TARAF PERKAHWINAN, BILANGAN TANGGUNGAN, BANGSA/AGAMA, TARAF PENDIDIKAN,
      //   JENIS KEDIAMAN, TEMPOH MENETAP, ALAMAT EMAIL, NAMA IBU, NO TEL, NO IC
      if (section === 1) {
        // --- Mother's fields (specific, checked first) ---
        if (rawKey.includes('nama') && rawKey.includes('ibu')) { if(setVal('applicant_nama_ibu', value)) filled++; }
        else if (rawKey.includes('ic') && rawKey.includes('ibu')) { if(setVal('applicant_ic_ibu', value)) filled++; }
        else if (rawKey.includes('tel') && rawKey.includes('ibu')) { if(setVal('applicant_hp_ibu', value)) filled++; }
        // "NO IC" (no "ibu" word, but appears AFTER nama ibu in BPA) — check if nama_ibu already filled
        else if (rawKey === 'no ic' && document.querySelector('[name="applicant_nama_ibu"]')?.value) { if(setVal('applicant_ic_ibu', value)) filled++; }
        // "NO TEL" (no "ibu"/"hp" word, but appears AFTER nama ibu in BPA) — check if nama_ibu already filled
        else if (rawKey === 'no tel' && document.querySelector('[name="applicant_nama_ibu"]')?.value) { if(setVal('applicant_hp_ibu', value)) filled++; }

        // --- Compound keys (multi-word, checked before single-word) ---
        else if (rawKey.includes('kad pengenalan')) { if(setVal('applicant_ic', value)) filled++; }
        else if (rawKey.includes('alamat') && rawKey.includes('email')) { if(setVal('applicant_email', value)) filled++; }
        else if (rawKey.includes('alamat')) { if(setVal('applicant_address', value)) filled++; }
        else if (rawKey.includes('tel') && rawKey.includes('hp')) { if(setVal('applicant_phone', value)) filled++; }
        else if (rawKey.includes('perkahwinan')) { if(setVal('applicant_taraf_perkahwinan', value)) filled++; }
        else if (rawKey.includes('tanggungan')) { if(setVal('applicant_tanggungan', value)) filled++; }
        else if (rawKey.includes('bangsa') || rawKey.includes('agama')) { if(setVal('applicant_bangsa_agama', value)) filled++; }
        else if (rawKey.includes('pendidikan')) { if(setVal('applicant_pendidikan', value)) filled++; }
        else if (rawKey.includes('kediaman')) { if(setVal('applicant_jenis_kediaman', value)) filled++; }
        else if (rawKey.includes('tempoh') || rawKey.includes('menetap')) { if(setVal('applicant_tempoh_menetap', value)) filled++; }
        else if (rawKey.includes('email')) { if(setVal('applicant_email', value)) filled++; }

        // --- Generic single-word (last resort) ---
        else if (rawKey.includes('nama')) { if(setVal('applicant_name', value)) filled++; }
        else if (rawKey.includes('kp') || rawKey.includes('ic')) { if(setVal('applicant_ic', value)) filled++; }
        else if (rawKey.includes('tel')) { if(setVal('applicant_phone', value)) filled++; }
      }

      // === SECTION 2: MAKLUMAT PASANGAN / IBU BAPA ===
      // BPA order: NAMA, NO IC, TEL BIMBIT, HUBUNGAN
      else if (section === 2) {
        if (rawKey.includes('nama')) { if(setVal('spouse_name', value)) filled++; }
        else if (rawKey.includes('ic') || rawKey.includes('kp')) { if(setVal('spouse_ic', value)) filled++; }
        else if (rawKey.includes('bimbit') || rawKey.includes('tel')) { if(setVal('spouse_phone', value)) filled++; }
        else if (rawKey.includes('hubungan')) { if(setVal('spouse_hubungan', value)) filled++; }
      }

      // === SECTION 3: MAKLUMAT PEKERJAAN ===
      // BPA order: NAMA MAJIKAN, ALAMAT MAJIKAN, NO TEL PEJBT, JAWATAN,
      //   TARIKH LANTIKAN, OPSYEN PENCEN, STATUS JAWATAN
      else if (section === 3) {
        if (rawKey.includes('nama') && rawKey.includes('majikan')) { if(setVal('job_employer', value)) filled++; }
        else if (rawKey.includes('nama') && !rawKey.includes('majikan')) { if(setVal('job_employer', value)) filled++; }
        else if (rawKey.includes('alamat')) { if(setVal('job_alamat_majikan', value)) filled++; }
        else if (rawKey.includes('pejbt') || rawKey.includes('pejabat')) { if(setVal('job_tel_pejabat', value)) filled++; }
        else if (rawKey.includes('status') && rawKey.includes('jawatan')) { if(setVal('job_status_jawatan', value)) filled++; }
        else if (rawKey.includes('jawatan')) { if(setVal('job_position', value)) filled++; }
        else if (rawKey.includes('tarikh') || rawKey.includes('lantikan')) { if(setVal('job_tarikh_mula', value)) filled++; }
        else if (rawKey.includes('pencen') || rawKey.includes('opsyen')) { if(setVal('job_opsyen_pencen', value)) filled++; }
        else if (rawKey.includes('status')) { if(setVal('job_status_jawatan', value)) filled++; }
        else if (rawKey.includes('tel')) { if(setVal('job_tel_pejabat', value)) filled++; }
        else if (rawKey.includes('payslip') && rawKey.includes('link')) { if(setVal('job_payslip_link', value)) filled++; }
        else if (rawKey.includes('anm') || (rawKey.includes('payslip') && rawKey.includes('password'))) { if(setVal('job_payslip_password', value)) filled++; }
        else if (rawKey.includes('hrmis')) { if(setVal('job_hrmis_password', value)) filled++; }
      }

      // === SECTION 4: RUJUKAN SAUDARA TERDEKAT ===
      // BPA order: NAMA, IC NO, NO TELEFON, ALAMAT, PERTALIAN
      else if (section === 4) {
        if (rawKey.includes('nama')) { if(setVal('ref_name', value)) filled++; }
        else if (rawKey.includes('ic')) { if(setVal('ref_ic', value)) filled++; }
        else if (rawKey.includes('tel') || rawKey.includes('telefon')) { if(setVal('ref_phone', value)) filled++; }
        else if (rawKey.includes('alamat')) { if(setVal('ref_address', value)) filled++; }
        else if (rawKey.includes('pertalian') || rawKey.includes('hubungan')) { if(setVal('ref_relationship', value)) filled++; }
      }
    }

    return filled;
  }

  // Fill N/A for fields that were not filled by WhatsApp
  function fillNAForEmpty() {
    const allFields = [
      'applicant_name','applicant_ic','applicant_phone','applicant_email','applicant_address',
      'applicant_taraf_perkahwinan','applicant_tanggungan','applicant_bangsa_agama',
      'applicant_pendidikan','applicant_jenis_kediaman','applicant_tempoh_menetap',
      'applicant_nama_ibu','applicant_ic_ibu','applicant_hp_ibu',
      'spouse_name','spouse_ic','spouse_phone','spouse_hubungan',
      'job_employer','job_alamat_majikan','job_tel_pejabat','job_position','job_tarikh_mula',
      'job_opsyen_pencen','job_status_jawatan',
      'ref_name','ref_ic','ref_address','ref_phone','ref_relationship'
    ];
    allFields.forEach(function(name) {
      const el = document.querySelector('[name="' + name + '"]');
      if (el && !el.value.trim()) {
        el.value = 'N/A';
      }
    });
  }

  btnAutoFill.addEventListener('click', function() {
    const text = waInput.value.trim();
    if (!text) {
      showResult('Please paste a WhatsApp message first.', true);
      return;
    }
    const filled = parseWhatsApp(text);
    if (filled > 0) {
      fillNAForEmpty();
      showResult('✅ Successfully filled ' + filled + ' fields automatically. Empty fields were set to N/A.', false);
    } else {
      showResult('⚠️ No fields could be filled. Please check the WhatsApp message format.', true);
    }
  });

  btnClearWa.addEventListener('click', function() {
    waInput.value = '';
    waResult.classList.add('hidden');
  });
})();

// --- Searchable Agent Assignment ---
(function() {
  const search = document.getElementById('agentSearch');
  const dropdown = document.getElementById('agentDropdown');
  const hidden = document.getElementById('assignAgentHidden');
  const badge = document.getElementById('selectedAgentBadge');
  const clearBtn = document.getElementById('clearAgent');
  const noResult = document.getElementById('agentNoResult');
  if (!search || !dropdown) return;

  const options = dropdown.querySelectorAll('.agent-option');

  function selectAgent(id, name, role) {
    hidden.value = id;
    search.value = name;
    dropdown.classList.add('hidden');
    const roleLabel = role === 'masteragent' ? 'Manager' : 'User';
    badge.textContent = name + ' (' + roleLabel + ')';
    badge.classList.remove('hidden');
  }

  function clearSelection() {
    hidden.value = '';
    search.value = '';
    badge.classList.add('hidden');
    badge.textContent = '';
  }

  function filterOptions() {
    const q = search.value.toLowerCase();
    let visible = 0;
    options.forEach(opt => {
      const name = opt.dataset.name.toLowerCase();
      const ref = opt.dataset.ref.toLowerCase();
      const role = opt.dataset.role.toLowerCase();
      const match = name.includes(q) || ref.includes(q) || role.includes(q);
      opt.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (noResult) noResult.classList.toggle('hidden', visible > 0);
  }

  search.addEventListener('focus', function() {
    dropdown.classList.remove('hidden');
    filterOptions();
  });

  search.addEventListener('input', function() {
    dropdown.classList.remove('hidden');
    hidden.value = '';
    badge.classList.add('hidden');
    filterOptions();
  });

  options.forEach(opt => {
    opt.addEventListener('click', function() {
      selectAgent(this.dataset.id, this.dataset.name, this.dataset.role);
    });
  });

  clearBtn.addEventListener('click', clearSelection);

  document.addEventListener('click', function(e) {
    if (!search.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });

  // Pre-select if editing a draft
  if (hidden.value) {
    const preselected = dropdown.querySelector('.agent-option[data-id="' + hidden.value + '"]');
    if (preselected) {
      selectAgent(preselected.dataset.id, preselected.dataset.name, preselected.dataset.role);
    }
  }
})();
</script>
<% if (typeof siteSettings !== 'undefined' && siteSettings.force_uppercase === 'true') { %>
<style>
  input[type="text"], input[type="tel"], textarea {
    text-transform: uppercase;
  }
  input[type="email"],
  input[name*="password"],
  input[name*="email"],
  #waMessageInput {
    text-transform: none !important;
  }
  input[type="text"]::placeholder, input[type="tel"]::placeholder, textarea::placeholder {
    text-transform: none;
  }
</style>
<script>
document.querySelectorAll('input[type="text"], input[type="tel"], textarea').forEach(function(el) {
  if (el.name && (el.name.includes('password') || el.name.includes('email'))) return;
  if (el.id === 'waMessageInput') return;
  el.addEventListener('input', function() {
    var s = this.selectionStart, e = this.selectionEnd;
    this.value = this.value.toUpperCase();
    this.setSelectionRange(s, e);
  });
});
</script>
<% } %>
