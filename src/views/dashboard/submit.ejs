          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Opsyen Pencen</label>
          <input type="text" name="job_opsyen_pencen" value="<%= j.opsyen_pencen || '' %>" required placeholder="cth: Ya / Tidak" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
