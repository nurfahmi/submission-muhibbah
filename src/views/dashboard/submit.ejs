<!-- Status Modal -->
<% const hasSuccess = typeof success !== 'undefined' && success && success.length > 0; %>
<% const hasError = typeof error !== 'undefined' && error && error.length > 0; %>
<% if (hasSuccess || hasError) { %>
<div id="statusModal" class="fixed inset-0 z-[60] flex items-center justify-center bg-black/50 backdrop-blur-sm">
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 p-8 max-w-sm w-full mx-4 text-center animate-[fadeIn_0.3s_ease-out]">
    <% if (hasSuccess) { %>
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
        <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h3 class="text-lg font-bold text-green-600 dark:text-green-400 mb-2">Success!</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-6"><%= success %></p>
    <% } else { %>
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </div>
      <h3 class="text-lg font-bold text-red-600 dark:text-red-400 mb-2">Failed!</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-6"><%= error %></p>
    <% } %>
    <button onclick="document.getElementById('statusModal').remove()"
      class="w-full bg-primary-600 hover:bg-primary-700 text-white font-semibold py-2.5 rounded-xl text-sm transition-colors">
      Close
    </button>
  </div>
</div>
<% } %>

<div style="display:flex;gap:1.5rem;align-items:flex-start;">
<div style="flex:2;min-width:0;">

  <!-- WhatsApp Auto-Fill -->
