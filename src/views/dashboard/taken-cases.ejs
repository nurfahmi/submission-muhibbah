<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <div class="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-sm px-4 py-3 rounded-xl mb-6"><%= success %></div>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <div class="bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 text-sm px-4 py-3 rounded-xl mb-6"><%= error %></div>
<% } %>
<%
  const productMap = {};
  if (typeof loanProducts !== 'undefined') {
    loanProducts.forEach(p => {
      productMap[p.key] = p.label;
      if (p.children) p.children.forEach(c => { productMap[c.key] = p.label; });
    });
  }
  function getProductName(key) { return key ? (productMap[key] || key) : '-'; }
  const f = typeof filters !== 'undefined' ? filters : {};
  const _total = typeof total !== 'undefined' ? total : submissions.length;
  const _page = typeof page !== 'undefined' ? page : 1;
  const _perPage = typeof perPage !== 'undefined' ? perPage : 20;
  const _totalPages = typeof totalPages !== 'undefined' ? totalPages : 1;
  const _takerList = typeof takerList !== 'undefined' ? takerList : [];
  const _period = typeof period !== 'undefined' ? period : 'this_month';

  const periods = [
    { key: 'this_month', label: 'This Month' },
    { key: 'last_month', label: 'Last Month' },
    { key: 'last_3_months', label: '3 Months' },
    { key: 'this_year', label: 'This Year' },
    { key: 'all', label: 'All' },
    { key: 'custom', label: 'Custom' }
  ];
%>

<!-- Summary Cards -->
<div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Kes Ditemui</p>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= _total %></p>
  </div>
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Halaman</p>
    <p class="text-2xl font-bold text-primary-600 dark:text-primary-400"><%= _page %> / <%= _totalPages %></p>
  </div>
  <% if (user.role === 'superadmin' || user.role === 'admin') { %>
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Admin/Staff</p>
    <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= _takerList.length %></p>
  </div>
  <% } %>
</div>

<div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800">
  <!-- Header -->
  <div class="px-4 sm:px-6 py-4 border-b border-gray-200 dark:border-gray-800">
    <h3 class="text-base font-semibold mb-3">Taken Cases</h3>

    <!-- Period Buttons -->
    <div class="flex flex-wrap gap-2 mb-3">
      <% periods.forEach(p => { %>
        <% if (p.key === 'custom') { %>
          <button type="button" id="btnCustom"
            class="px-3 py-1.5 rounded-lg text-xs font-medium transition-colors
              <%= _period === 'custom' ? 'bg-primary-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %>">
            <%= p.label %>
          </button>
        <% } else { %>
          <a href="/dashboard/taken-cases?period=<%= p.key %><%= f.taker ? '&taker=' + f.taker : '' %><%= f.search ? '&search=' + encodeURIComponent(f.search) : '' %>"
            class="px-3 py-1.5 rounded-lg text-xs font-medium transition-colors
              <%= _period === p.key ? 'bg-primary-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %>">
            <%= p.label %>
          </a>
        <% } %>
      <% }) %>
    </div>

    <!-- Custom Date Range (hidden by default, shown when custom selected) -->
    <div id="customRange" class="<%= _period === 'custom' ? '' : 'hidden' %> mb-3">
      <form method="GET" action="/dashboard/taken-cases" class="flex flex-wrap items-end gap-3">
        <input type="hidden" name="period" value="custom">
        <% if (f.taker) { %><input type="hidden" name="taker" value="<%= f.taker %>"><% } %>
        <% if (f.search) { %><input type="hidden" name="search" value="<%= f.search %>"><% } %>
        <div class="min-w-[140px]">
          <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">From</label>
          <input type="date" name="dateFrom" value="<%= f.dateFrom || '' %>"
            class="w-full px-3 py-1.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
        </div>
        <div class="min-w-[140px]">
          <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">To</label>
          <input type="date" name="dateTo" value="<%= f.dateTo || '' %>"
            class="w-full px-3 py-1.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
        </div>
        <button type="submit" class="px-4 py-1.5 rounded-lg text-xs font-medium bg-primary-600 hover:bg-primary-700 text-white transition-colors">Apply</button>
      </form>
    </div>

    <!-- Search + Admin Filter -->
    <form method="GET" action="/dashboard/taken-cases" class="flex flex-wrap items-end gap-3">
      <input type="hidden" name="period" value="<%= _period %>">
      <% if (_period === 'custom') { %>
        <input type="hidden" name="dateFrom" value="<%= f.dateFrom || '' %>">
        <input type="hidden" name="dateTo" value="<%= f.dateTo || '' %>">
      <% } %>
      <div class="flex-1 min-w-[160px] max-w-[240px]">
        <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Search</label>
        <input type="text" name="search" value="<%= f.search || '' %>" placeholder="Name, IC, Employer..."
          class="w-full px-3 py-1.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
      </div>
      <% if (user.role === 'superadmin' || user.role === 'admin') { %>
      <div class="min-w-[140px] max-w-[200px]">
        <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Taken By</label>
        <select name="taker"
          class="w-full px-3 py-1.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
          <option value="">All</option>
          <% _takerList.forEach(t => { %>
            <option value="<%= t.id %>" <%= (f.taker === t.id) ? 'selected' : '' %>><%= t.username %></option>
          <% }) %>
        </select>
      </div>
      <% } %>
      <button type="submit" class="px-4 py-1.5 rounded-lg text-xs font-medium bg-primary-600 hover:bg-primary-700 text-white transition-colors">Filter</button>
    </form>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 dark:border-gray-800">
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Customer</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">IC</th>
          <% if (user.role === 'superadmin' || user.role === 'admin') { %>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Manager</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">User</th>
          <% } else if (user.role === 'masteragent') { %>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Agent</th>
          <% } %>
          <th class="text-center px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Taken By</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden md:table-cell">Date</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Product</th>
          <th class="text-center px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Action</th>
        </tr>
      </thead>
      <tbody>
        <% const colCount = (user.role === 'superadmin' || user.role === 'admin') ? 8 : (user.role === 'masteragent') ? 7 : 6; %>
        <% if (submissions.length === 0) { %>
          <tr><td colspan="<%= colCount %>" class="px-3 sm:px-6 py-8 text-center text-gray-400">No cases found</td></tr>
        <% } %>
        <% submissions.forEach(s => { %>
          <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
            <td class="px-3 sm:px-6 py-3 font-medium">
              <div class="flex items-center gap-2">
                <span><%= s.applicant_name %></span>
                <% if (s.needs_image_review) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300" title="Gambar perlu disemak">📷</span>
                <% } %>
              </div>
              <div class="text-xs text-gray-400 sm:hidden"><%= s.applicant_ic !== '-' ? s.applicant_ic : '' %></div>
            </td>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell font-mono text-xs"><%= s.applicant_ic %></td>
            <% if (user.role === 'superadmin' || user.role === 'admin') { %>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= s.masteragent_name %></td>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= s.subagent_name || '-' %></td>
            <% } else if (user.role === 'masteragent') { %>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= s.subagent_name %></td>
            <% } %>
            <td class="px-3 sm:px-6 py-3 text-center">
              <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300"><%= s.taken_by_name || '-' %></span>
            </td>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 text-xs hidden md:table-cell"><%= s.taken_at ? new Date(s.taken_at).toLocaleDateString('ms-MY') : '-' %></td>
            <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell text-xs"><%= getProductName(s.product_key) %></td>
            <td class="px-3 sm:px-6 py-3 text-center">
              <% const canView = (user.role === 'superadmin' || user.role === 'admin') || (s.taken_by === user.id); %>
              <% if (canView) { %>
                <a href="/dashboard/cases/<%= s.id %>" class="px-3 py-1.5 text-xs font-medium bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 rounded-lg hover:bg-primary-100 dark:hover:bg-primary-900/30 transition-colors">View</a>
              <% } else { %>
                <span class="px-3 py-1.5 text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-500 rounded-lg cursor-not-allowed">View</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Server-side Pagination -->
  <% if (_totalPages > 1) { %>
  <%
    function pgUrl(p) {
      const params = new URLSearchParams();
      params.set('period', _period);
      if (f.search) params.set('search', f.search);
      if (_period === 'custom') {
        if (f.dateFrom) params.set('dateFrom', f.dateFrom);
        if (f.dateTo) params.set('dateTo', f.dateTo);
      }
      if (f.taker) params.set('taker', f.taker);
      params.set('page', p);
      return '/dashboard/taken-cases?' + params.toString();
    }
    const fromItem = (_page - 1) * _perPage + 1;
    const toItem = Math.min(_page * _perPage, _total);
  %>
  <div class="px-4 sm:px-6 py-3 border-t border-gray-200 dark:border-gray-800 flex items-center justify-between">
    <p class="text-xs text-gray-500 dark:text-gray-400">
      Showing <span class="font-medium"><%= fromItem %></span>–<span class="font-medium"><%= toItem %></span> of <span class="font-medium"><%= _total %></span>
    </p>
    <div class="flex items-center gap-1">
      <% if (_page > 1) { %>
        <a href="<%= pgUrl(_page - 1) %>" class="px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">← Prev</a>
      <% } else { %>
        <span class="px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-500 opacity-40 cursor-not-allowed">← Prev</span>
      <% } %>
      <span class="text-xs text-gray-500 dark:text-gray-400 px-2"><%= _page %> / <%= _totalPages %></span>
      <% if (_page < _totalPages) { %>
        <a href="<%= pgUrl(_page + 1) %>" class="px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">Next →</a>
      <% } else { %>
        <span class="px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-500 opacity-40 cursor-not-allowed">Next →</span>
      <% } %>
    </div>
  </div>
  <% } %>
</div>

<script>
document.getElementById('btnCustom')?.addEventListener('click', function() {
  document.getElementById('customRange')?.classList.toggle('hidden');
});
</script>
