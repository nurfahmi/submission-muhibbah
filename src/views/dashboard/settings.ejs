<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <div class="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-sm px-4 py-3 rounded-xl mb-6"><%= success %></div>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <div class="bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 text-sm px-4 py-3 rounded-xl mb-6"><%= error %></div>
<% } %>

<form method="POST" action="/dashboard/settings" enctype="multipart/form-data">
<div class="max-w-3xl">

  <!-- Tab Navigation -->
  <div class="flex gap-1 mb-6 bg-gray-100 dark:bg-gray-800/50 rounded-xl p-1 overflow-x-auto">
    <button type="button" data-tab="branding" class="settings-tab flex-1 min-w-0 px-4 py-2.5 rounded-lg text-sm font-medium transition-all whitespace-nowrap">
      🎨 Branding
    </button>
    <button type="button" data-tab="form" class="settings-tab flex-1 min-w-0 px-4 py-2.5 rounded-lg text-sm font-medium transition-all whitespace-nowrap">
      📝 Submission
    </button>
    <button type="button" data-tab="quality" class="settings-tab flex-1 min-w-0 px-4 py-2.5 rounded-lg text-sm font-medium transition-all whitespace-nowrap">
      📷 Quality
    </button>
    <% if (user.role === 'superadmin') { %>
    <button type="button" data-tab="storage" class="settings-tab flex-1 min-w-0 px-4 py-2.5 rounded-lg text-sm font-medium transition-all whitespace-nowrap">
      📁 Storage
    </button>
    <% } %>
  </div>

  <!-- Tab: Branding -->
  <div id="tab-branding" class="settings-panel space-y-5">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6 space-y-5">
      <h3 class="text-base font-semibold flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-sm">🎨</span>
        Branding & Appearance
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Site Name</label>
          <input type="text" name="site_name" value="<%= settings.site_name %>"
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Short Name</label>
          <input type="text" name="site_short" value="<%= settings.site_short %>"
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
        </div>
      </div>

      <!-- Logo -->
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Logo</label>
        <div class="flex items-center gap-4">
          <% if (settings.logo_url) { %>
            <img src="<%= settings.logo_url %>" alt="Logo" class="w-12 h-12 rounded-xl object-cover border border-gray-200 dark:border-gray-700">
          <% } else { %>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-lg border border-gray-200 dark:border-gray-700" style="background-color: <%= settings.primary_color %>" id="previewLogo">
              <%= settings.site_short.charAt(0) %>
            </div>
          <% } %>
          <div class="flex-1">
            <input type="file" name="logo_file" accept=".jpg,.jpeg,.png,.svg,.webp"
              class="w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-medium file:bg-primary-50 dark:file:bg-primary-900/30 file:text-primary-700 dark:file:text-primary-300 hover:file:bg-primary-100">
            <p class="text-xs text-gray-400 mt-1">JPG, PNG, SVG, WebP. Max 2MB.</p>
          </div>
        </div>
      </div>

      <!-- Favicon -->
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Favicon</label>
        <div class="flex items-center gap-4">
          <% if (settings.favicon_url) { %>
            <img src="<%= settings.favicon_url %>" alt="Favicon" class="w-8 h-8 rounded border border-gray-200 dark:border-gray-700">
          <% } else { %>
            <div class="w-8 h-8 rounded flex items-center justify-center bg-gray-200 dark:bg-gray-700 text-xs font-bold text-gray-500">—</div>
          <% } %>
          <div class="flex-1">
            <input type="file" name="favicon_file" accept=".jpg,.jpeg,.png,.ico,.svg,.webp"
              class="w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-medium file:bg-primary-50 dark:file:bg-primary-900/30 file:text-primary-700 dark:file:text-primary-300 hover:file:bg-primary-100">
            <p class="text-xs text-gray-400 mt-1">ICO, PNG, SVG. Max 2MB.</p>
          </div>
        </div>
      </div>

      <!-- Colors -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Primary Color</label>
          <div class="flex items-center gap-3">
            <input type="color" name="primary_color" value="<%= settings.primary_color %>" id="primaryPicker"
              class="w-10 h-10 rounded-lg border border-gray-300 dark:border-gray-700 cursor-pointer">
            <input type="text" id="primaryHex" value="<%= settings.primary_color %>" readonly
              class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none font-mono">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Accent Color</label>
          <div class="flex items-center gap-3">
            <input type="color" name="accent_color" value="<%= settings.accent_color %>" id="accentPicker"
              class="w-10 h-10 rounded-lg border border-gray-300 dark:border-gray-700 cursor-pointer">
            <input type="text" id="accentHex" value="<%= settings.accent_color %>" readonly
              class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none font-mono">
          </div>
        </div>
      </div>

      <!-- Preview -->
      <div class="border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-3">Preview</p>
        <div class="flex items-center gap-4">
          <% if (settings.logo_url) { %>
            <img src="<%= settings.logo_url %>" alt="Logo" class="w-12 h-12 rounded-xl object-cover">
          <% } else { %>
            <div id="previewLogoBox" class="w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-lg" style="background-color: <%= settings.primary_color %>">
              <%= settings.site_short.charAt(0) %>
            </div>
          <% } %>
          <div>
            <p class="font-semibold" id="previewName"><%= settings.site_name %></p>
            <p class="text-xs text-gray-400" id="previewShort"><%= settings.site_short %></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab: Submission Form -->
  <div id="tab-form" class="settings-panel hidden space-y-5">
    <!-- Force Uppercase -->
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6 space-y-5">
      <h3 class="text-base font-semibold flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-sm">📝</span>
        Form Settings
      </h3>

      <div class="flex items-center justify-between py-2">
        <div>
          <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Force Uppercase</label>
          <p class="text-xs text-gray-400">Auto-convert all text inputs to UPPERCASE</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="hidden" name="force_uppercase" value="false">
          <input type="checkbox" name="force_uppercase" value="true" <%= settings.force_uppercase === 'true' ? 'checked' : '' %> class="sr-only peer">
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-300 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-600"></div>
        </label>
      </div>
    </div>

    <!-- Required Documents -->
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6">
      <h3 class="text-base font-semibold flex items-center gap-2 mb-1">
        <span class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center text-sm">📎</span>
        Required Documents
      </h3>
      <p class="text-xs text-gray-400 mb-5">Toggle which documents are mandatory when submitting an application</p>

      <div class="space-y-0 divide-y divide-gray-100 dark:divide-gray-800">
        <%
          const fileFields = [
            { key: 'ic_depan', label: 'IC Front', desc: 'Front of identity card' },
            { key: 'ic_belakang', label: 'IC Back', desc: 'Back of identity card' },
            { key: 'payslip1', label: 'Latest Payslip 1', desc: 'Most recent month payslip' },
            { key: 'payslip2', label: 'Latest Payslip 2', desc: 'Second month payslip' },
            { key: 'payslip3', label: 'Latest Payslip 3', desc: 'Third month payslip' },
            { key: 'bank_page', label: 'Bank Account Page', desc: 'Front page of bank account book' },
            { key: 'signature', label: 'Customer Signature', desc: 'Applicant signature image' },
            { key: 'chop_sign', label: 'Employer Chop & Sign', desc: 'Round stamp, name stamp & employer signature' },
            { key: 'bill_rumah', label: 'Utility Bill', desc: 'Utility / house rental bill' },
            { key: 'settlement_letter', label: 'Settlement Letter', desc: 'Debt settlement letter' }
          ];
        %>
        <% fileFields.forEach(f => { %>
        <div class="flex items-center justify-between py-3">
          <div>
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300"><%= f.label %></label>
            <p class="text-xs text-gray-400"><%= f.desc %></p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer shrink-0 ml-4">
            <input type="hidden" name="req_<%= f.key %>" value="false">
            <input type="checkbox" name="req_<%= f.key %>" value="true" <%= settings['req_' + f.key] === 'true' ? 'checked' : '' %> class="sr-only peer">
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-300 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-600"></div>
          </label>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Tab: Image Quality -->
  <div id="tab-quality" class="settings-panel hidden">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6 space-y-5">
      <h3 class="text-base font-semibold flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-sm">📷</span>
        Image Quality Check
      </h3>

      <div class="flex items-center justify-between py-2">
        <div>
          <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Enable Quality Check</label>
          <p class="text-xs text-gray-400">Check uploaded images for blur & overexposure</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="hidden" name="iq_enabled" value="false">
          <input type="checkbox" name="iq_enabled" value="true" <%= settings.iq_enabled === 'true' ? 'checked' : '' %> class="sr-only peer">
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-300 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-600"></div>
        </label>
      </div>

      <div class="flex items-center justify-between py-2">
        <div>
          <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Block Upload on Issues</label>
          <p class="text-xs text-gray-400">If ON, user must re-upload. If OFF, only warning shown.</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="hidden" name="iq_block_upload" value="false">
          <input type="checkbox" name="iq_block_upload" value="true" <%= settings.iq_block_upload === 'true' ? 'checked' : '' %> class="sr-only peer">
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-300 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-600"></div>
        </label>
      </div>

      <div class="border-t border-gray-100 dark:border-gray-800 pt-4 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            Blur Sensitivity: <span id="blurVal"><%= settings.iq_blur_threshold %></span>
          </label>
          <input type="range" name="iq_blur_threshold" min="10" max="300" step="10" value="<%= settings.iq_blur_threshold %>"
            oninput="document.getElementById('blurVal').textContent=this.value"
            class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-lg appearance-none cursor-pointer accent-primary-600">
          <div class="flex justify-between text-xs text-gray-400 mt-1">
            <span>Low (10)</span><span>High (300)</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">Higher = more strict. Recommended: 30-80</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            Overexposure Brightness: <span id="brightVal"><%= settings.iq_bright_threshold %></span>
          </label>
          <input type="range" name="iq_bright_threshold" min="200" max="255" step="5" value="<%= settings.iq_bright_threshold %>"
            oninput="document.getElementById('brightVal').textContent=this.value"
            class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-lg appearance-none cursor-pointer accent-primary-600">
          <div class="flex justify-between text-xs text-gray-400 mt-1">
            <span>Strict (200)</span><span>Lenient (255)</span>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            Overexposure Area %: <span id="brightPctVal"><%= settings.iq_bright_percent %></span>%
          </label>
          <input type="range" name="iq_bright_percent" min="10" max="80" step="5" value="<%= settings.iq_bright_percent %>"
            oninput="document.getElementById('brightPctVal').textContent=this.value"
            class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-lg appearance-none cursor-pointer accent-primary-600">
          <div class="flex justify-between text-xs text-gray-400 mt-1">
            <span>Strict (10%)</span><span>Lenient (80%)</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">% of image that must be bright to flag as overexposed</p>
        </div>
      </div>
    </div>
  </div>

  <% if (user.role === 'superadmin') { %>
  <!-- Tab: Storage -->
  <div id="tab-storage" class="settings-panel hidden">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6 space-y-5">
      <h3 class="text-base font-semibold flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-sm">📁</span>
        Storage Directory
      </h3>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Upload Directory Path</label>
        <div class="flex gap-2">
          <input type="text" name="upload_dir" id="uploadDirInput" value="<%= settings.upload_dir || '' %>" placeholder="Leave empty for default (./uploads)"
            class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500 font-mono">
          <button type="button" id="browseDirBtn"
            class="shrink-0 px-4 py-2.5 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 rounded-xl text-sm font-medium transition-colors">
            Browse
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-1">Absolute path for file storage. e.g. <code>/Volumes/ExternalSSD/uploads</code></p>
        <p class="text-xs text-gray-400 mt-0.5">Files are organized as: <code>{upload_dir}/submissions/{YYYY-MM}/{IC}/</code></p>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Save Button (always visible) -->
  <div class="mt-6">
    <button type="submit"
      class="w-full bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 rounded-xl text-sm transition-colors">
      Save Settings
    </button>
  </div>

</div>
</form>

<!-- Directory Browser Modal -->
<div id="dirBrowserModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 w-full max-w-lg mx-4 max-h-[70vh] flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200">📁 Browse Server Directories</h3>
      <button type="button" id="closeDirBrowser" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 text-lg">&times;</button>
    </div>
    <div class="px-5 py-3 border-b border-gray-100 dark:border-gray-800">
      <p id="dirCurrentPath" class="text-xs font-mono text-gray-500 dark:text-gray-400 truncate">/</p>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-2" id="dirListing">
      <p class="text-sm text-gray-400 py-4 text-center">Loading...</p>
    </div>
    <div class="px-5 py-4 border-t border-gray-200 dark:border-gray-700 flex gap-2">
      <button type="button" id="selectDirBtn"
        class="flex-1 bg-primary-600 hover:bg-primary-700 text-white font-medium py-2 rounded-xl text-sm transition-colors">
        Select This Folder
      </button>
      <button type="button" id="cancelDirBtn"
        class="px-4 py-2 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 rounded-xl text-sm font-medium transition-colors">
        Cancel
      </button>
    </div>
  </div>
</div>

<script>
// --- Tab Switching ---
(function() {
  const tabs = document.querySelectorAll('.settings-tab');
  const panels = document.querySelectorAll('.settings-panel');

  function switchTab(tabName) {
    tabs.forEach(t => {
      if (t.dataset.tab === tabName) {
        t.classList.add('bg-white', 'dark:bg-gray-900', 'shadow-sm', 'text-gray-900', 'dark:text-gray-100');
        t.classList.remove('text-gray-500', 'dark:text-gray-400', 'hover:text-gray-700', 'dark:hover:text-gray-300');
      } else {
        t.classList.remove('bg-white', 'dark:bg-gray-900', 'shadow-sm', 'text-gray-900', 'dark:text-gray-100');
        t.classList.add('text-gray-500', 'dark:text-gray-400', 'hover:text-gray-700', 'dark:hover:text-gray-300');
      }
    });
    panels.forEach(p => {
      p.classList.toggle('hidden', p.id !== 'tab-' + tabName);
    });
    localStorage.setItem('settingsTab', tabName);
  }

  tabs.forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

  // Restore last active tab or default to branding
  const saved = localStorage.getItem('settingsTab');
  switchTab(saved && document.getElementById('tab-' + saved) ? saved : 'branding');
})();

// --- Color Pickers ---
document.getElementById('primaryPicker').addEventListener('input', function(e) {
  document.getElementById('primaryHex').value = e.target.value;
  var logo = document.getElementById('previewLogo') || document.getElementById('previewLogoBox');
  if (logo) logo.style.backgroundColor = e.target.value;
});
document.getElementById('accentPicker').addEventListener('input', function(e) {
  document.getElementById('accentHex').value = e.target.value;
});
document.querySelector('input[name="site_name"]').addEventListener('input', function(e) {
  document.getElementById('previewName').textContent = e.target.value;
});
document.querySelector('input[name="site_short"]').addEventListener('input', function(e) {
  document.getElementById('previewShort').textContent = e.target.value;
  var logo = document.getElementById('previewLogo') || document.getElementById('previewLogoBox');
  if (logo && !logo.tagName.match(/img/i)) logo.textContent = e.target.value.charAt(0);
});

// --- Directory Browser ---
(function() {
  var modal = document.getElementById('dirBrowserModal');
  var browseBtn = document.getElementById('browseDirBtn');
  var closeBtn = document.getElementById('closeDirBrowser');
  var cancelBtn = document.getElementById('cancelDirBtn');
  var selectBtn = document.getElementById('selectDirBtn');
  var listing = document.getElementById('dirListing');
  var currentPathEl = document.getElementById('dirCurrentPath');
  var input = document.getElementById('uploadDirInput');
  if (!browseBtn) return;

  var currentDir = '/';

  function openModal() {
    currentDir = input.value.trim() || '/';
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    loadDir(currentDir);
  }
  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function loadDir(dirPath) {
    currentDir = dirPath;
    currentPathEl.textContent = dirPath;
    listing.innerHTML = '<p class="text-sm text-gray-400 py-4 text-center">Loading...</p>';

    fetch('/dashboard/settings/browse-dir?path=' + encodeURIComponent(dirPath))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        currentDir = data.path;
        currentPathEl.textContent = data.path;

        if (data.error) {
          listing.innerHTML = '<p class="text-sm text-red-400 py-4 text-center">' + data.error + '</p>';
          return;
        }

        var html = '';
        if (data.parent) {
          html += '<button type="button" onclick="window._browseDir(\'' + data.parent.replace(/'/g, "\\'") + '\')" ' +
            'class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center gap-2 text-gray-500">' +
            '<span>⬆️</span> <span>..</span></button>';
        }

        if (data.dirs.length === 0 && !data.parent) {
          html += '<p class="text-sm text-gray-400 py-4 text-center">No folders found</p>';
        }

        data.dirs.forEach(function(d) {
          var fullPath = data.path === '/' ? '/' + d : data.path + '/' + d;
          html += '<button type="button" onclick="window._browseDir(\'' + fullPath.replace(/'/g, "\\'") + '\')" ' +
            'class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center gap-2 text-gray-700 dark:text-gray-300">' +
            '<span>📁</span> <span>' + d + '</span></button>';
        });

        listing.innerHTML = html;
      })
      .catch(function() {
        listing.innerHTML = '<p class="text-sm text-red-400 py-4 text-center">Failed to load</p>';
      });
  }

  window._browseDir = loadDir;

  browseBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  cancelBtn.addEventListener('click', closeModal);
  selectBtn.addEventListener('click', function() {
    input.value = currentDir;
    closeModal();
  });

  modal.addEventListener('click', function(e) {
    if (e.target === modal) closeModal();
  });
})();
</script>
