<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <div class="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-sm px-4 py-3 rounded-xl mb-6">
    <%= success %>
  </div>
<% } %>

<!-- Stats Cards -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-5">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-9 h-9 rounded-xl bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
        <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= stats.today %></p>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Hari Ini</p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-5">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-9 h-9 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= stats.thisWeek %></p>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Minggu Ini</p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-5">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-9 h-9 rounded-xl bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
        <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= stats.thisMonth %></p>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Bulan Ini</p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-5">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-9 h-9 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center">
        <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= stats.total %></p>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Total Kes</p>
  </div>
</div>

<!-- Agent Summary (admin/superadmin) -->
<% if (user.role === 'superadmin' || user.role === 'admin') { %>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-5 flex items-center gap-4">
    <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center">
      <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    </div>
    <div>
      <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= totalAgents %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400">Total Agent</p>
    </div>
  </div>
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-5 flex items-center gap-4">
    <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
      <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    </div>
    <div>
      <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= totalMaster %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400">Master Agent</p>
    </div>
  </div>
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-5 flex items-center gap-4">
    <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
      <svg class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    </div>
    <div>
      <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= totalSub %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400">Sub Agent</p>
    </div>
  </div>
</div>
<% } %>

<% if (typeof referralCode !== 'undefined' && referralCode && user.role !== 'superadmin' && user.role !== 'admin') { %>
<!-- Referral Link -->
<div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6 mb-8">
  <div class="flex items-center justify-between gap-4">
    <div class="min-w-0">
      <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Public Submission Link</p>
      <p class="text-xs text-gray-400 mb-2">Share this link with customers to submit applications under your referral.</p>
      <div class="flex items-center gap-2">
        <code id="refLink" class="flex-1 min-w-0 text-xs bg-gray-100 dark:bg-gray-800 px-3 py-2 rounded-lg font-mono truncate"><%= `${typeof req !== 'undefined' ? req.protocol + '://' + req.get('host') : ''}` %>/submit?ref=<%= referralCode %></code>
        <button onclick="copyRefLink()" id="copyBtn"
          class="shrink-0 px-3 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-xs font-medium transition-colors">
          Copy
        </button>
      </div>
    </div>
    <div class="shrink-0 text-right">
      <p class="text-xs text-gray-400">Referral Code</p>
      <p class="text-sm font-bold font-mono text-primary-600 dark:text-primary-400"><%= referralCode %></p>
    </div>
  </div>
</div>
<script>
function copyRefLink() {
  const link = document.getElementById('refLink').textContent;
  navigator.clipboard.writeText(link).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
  });
}
</script>
<% } %>

<!-- Recent Cases + Agent Performance -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Recent Cases (2/3 width) -->
  <div class="lg:col-span-2 bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-200 dark:border-gray-800 flex items-center justify-between">
      <h3 class="text-base font-semibold">
        <% if (user.role === 'superadmin' || user.role === 'admin') { %>
          Kes Belum Diambil
          <% if (recentCases.length > 0) { %>
            <span class="ml-2 inline-flex items-center justify-center px-2 py-0.5 rounded-full text-xs font-bold bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400"><%= recentCases.length %></span>
          <% } %>
        <% } else { %>
          Kes Terbaru
        <% } %>
      </h3>
      <a href="/dashboard/cases" class="text-xs text-primary-600 dark:text-primary-400 hover:underline font-medium">Lihat Semua →</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-800">
            <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Customer</th>
            <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Agent</th>
            <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden md:table-cell">Tarikh</th>
            <th class="text-center px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentCases.length === 0) { %>
            <tr><td colspan="4" class="px-3 sm:px-6 py-8 text-center text-gray-400">Tiada kes</td></tr>
          <% } %>
          <% recentCases.forEach(s => { %>
            <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-3 sm:px-6 py-3">
                <div class="font-medium"><%= s.applicant_name %></div>
                <div class="text-xs text-gray-400 sm:hidden"><%= s.applicant_ic !== '-' ? s.applicant_ic : '' %></div>
              </td>
              <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= s.agent_name %></td>
              <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 text-xs hidden md:table-cell"><%= new Date(s.created_at).toLocaleDateString('ms-MY') %></td>
              <td class="px-3 sm:px-6 py-3 text-center">
                <a href="/dashboard/cases/<%= s.id %>" class="px-2.5 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">View</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Agent Performance (1/3 width) -->
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-200 dark:border-gray-800">
      <h3 class="text-base font-semibold">Agent Performance</h3>
    </div>
    <div class="overflow-y-auto" style="max-height: 400px;">
      <% if (performance.length === 0) { %>
        <div class="px-4 sm:px-6 py-8 text-center text-gray-400 text-sm">No agents found</div>
      <% } %>
      <% performance.sort((a, b) => b.total - a.total).forEach((p, i) => { %>
        <div class="flex items-center gap-3 px-4 sm:px-6 py-3 border-b border-gray-100 dark:border-gray-800 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
          <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold
            <% if (i === 0) { %>bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300
            <% } else if (i === 1) { %>bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300
            <% } else if (i === 2) { %>bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300
            <% } else { %>bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400<% } %>"><%= i + 1 %></div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium truncate"><%= p.name %></p>
            <p class="text-xs text-gray-400 capitalize"><%= p.role === 'masteragent' ? 'Master' : 'Sub' %></p>
          </div>
          <div class="text-right">
            <p class="text-sm font-bold"><%= p.total %></p>
            <p class="text-xs text-gray-400">kes</p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
