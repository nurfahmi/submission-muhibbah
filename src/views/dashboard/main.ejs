<style>
  @keyframes highlightRow { from { background: rgba(14,165,233,0.15); } to { background: transparent; } }
</style>
<script>
(function() {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  let ws;

  function connect() {
    ws = new WebSocket(proto + '//' + location.host + '/ws/notifications');
    ws.onmessage = function(event) {
      try {
        const data = JSON.parse(event.data);
        if (data.type === 'NEW_CASE') {
          addCaseRow(data);
          updateBadge(1);
        } else if (data.type === 'CASE_TAKEN') {
          removeCaseRow(data.caseId);
          updateBadge(-1);
        } else if (data.type === 'CASE_MODIFIED') {
          addModifiedRow(data);
        }
      } catch(e) {}
    };
    ws.onclose = function() { setTimeout(connect, 5000); };
    ws.onerror = function() { ws.close(); };
  }

  function addCaseRow(data) {
    const tbody = document.querySelector('table tbody');
    if (!tbody) return;

    // Remove "Tiada kes" row if exists
    const emptyRow = tbody.querySelector('td[colspan]');
    if (emptyRow) emptyRow.closest('tr').remove();

    const tr = document.createElement('tr');
    tr.className = 'border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors';
    tr.dataset.caseId = data.caseId;
    tr.style.animation = 'highlightRow 3s ease-out';
    tr.innerHTML = `
      <td class="px-3 sm:px-6 py-3"><div class="font-medium">${data.applicantName}</div></td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 text-xs hidden sm:table-cell">-</td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell">${data.agentName}</td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 text-xs hidden md:table-cell">${data.date}</td>
      <td class="px-3 sm:px-6 py-3 text-center">
        <a href="/dashboard/cases/${data.caseId}" class="px-2.5 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">View</a>
      </td>`;
    tbody.insertBefore(tr, tbody.firstChild);
  }

  function removeCaseRow(caseId) {
    const tbody = document.querySelector('table tbody');
    if (!tbody) return;
    // Find by data-case-id or by link href
    let row = tbody.querySelector('tr[data-case-id="' + caseId + '"]');
    if (!row) {
      const link = tbody.querySelector('a[href="/dashboard/cases/' + caseId + '"]');
      if (link) row = link.closest('tr');
    }
    if (row) {
      row.style.transition = 'opacity 0.5s';
      row.style.opacity = '0';
      setTimeout(() => {
        row.remove();
        // Show "Tiada kes" if table is empty
        if (!tbody.querySelector('tr')) {
          const tr = document.createElement('tr');
          tr.innerHTML = '<td colspan="5" class="px-3 sm:px-6 py-8 text-center text-gray-400">Tiada kes</td>';
          tbody.appendChild(tr);
        }
      }, 500);
    }
  }

  function updateBadge(delta) {
    const badge = document.querySelector('h3 span');
    if (badge) {
      const newCount = Math.max(0, parseInt(badge.textContent || '0') + delta);
      if (newCount > 0) {
        badge.textContent = newCount;
      } else {
        badge.remove();
      }
    } else if (delta > 0) {
      const h3 = document.querySelector('h3.text-base');
      if (h3 && !h3.querySelector('span')) {
        const span = document.createElement('span');
        span.className = 'ml-2 inline-flex items-center justify-center px-2 py-0.5 rounded-full text-xs font-bold bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400';
        span.textContent = '1';
        h3.appendChild(span);
      }
    }
  }

  function addModifiedRow(data) {
    const tbody = document.getElementById('modifiedBody');
    if (!tbody) return;
    // Remove empty row
    const emptyRow = tbody.querySelector('td[colspan]');
    if (emptyRow) emptyRow.closest('tr').remove();
    // Remove existing row for same case (avoid duplicates)
    const existing = tbody.querySelector('a[href="/dashboard/cases/' + data.caseId + '"]');
    if (existing) existing.closest('tr').remove();
    // Insert at top
    const tr = document.createElement('tr');
    tr.className = 'modified-row border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors';
    tr.style.animation = 'highlightRow 3s ease-out';
    tr.innerHTML = `
      <td class="px-3 sm:px-6 py-3 font-medium">${data.applicantName}</td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 text-xs hidden sm:table-cell">${data.productKey || '-'}</td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell">${data.masteragentName || '-'}</td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 hidden sm:table-cell">${data.subagentName || '-'}</td>
      <td class="px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 text-xs hidden md:table-cell">${data.updatedAt}</td>
      <td class="px-3 sm:px-6 py-3 text-center">
        <a href="/dashboard/cases/${data.caseId}" class="px-2.5 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 rounded-lg text-xs font-medium hover:bg-orange-200 transition-colors">View</a>
      </td>`;
    tbody.insertBefore(tr, tbody.firstChild);
    // Keep max 10 rows
    while (tbody.children.length > 10) tbody.removeChild(tbody.lastChild);
  }

  connect();
})();
</script>
<% } %>
