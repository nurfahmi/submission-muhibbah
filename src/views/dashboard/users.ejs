<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <div class="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 text-sm px-4 py-3 rounded-xl mb-6"><%= success %></div>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <div class="bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 text-sm px-4 py-3 rounded-xl mb-6"><%= error %></div>
<% } %>

<%
  // Group users: non-agents, then managers with their users
  const roleLabel = (r) => ({ masteragent: 'Manager', subagent: 'User', admin: 'Admin', superadmin: 'Superadmin' }[r] || r);
  const admins = users.filter(u => u.role === 'superadmin' || u.role === 'admin');
  const masters = users.filter(u => u.role === 'masteragent');
  const subs = users.filter(u => u.role === 'subagent');
%>

<!-- User List -->
<div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800">
  <div class="px-4 sm:px-6 py-4 border-b border-gray-200 dark:border-gray-800 flex items-center justify-between">
    <h3 class="text-base font-semibold">Users (<%= users.length %>)</h3>
    <% if (creatableRoles.length > 0) { %>
      <button onclick="document.getElementById('createUserModal').classList.remove('hidden')"
        class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-xl text-sm font-medium transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add User
      </button>
    <% } %>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm" id="userTable">
      <thead>
        <tr class="border-b border-gray-200 dark:border-gray-800">
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Username</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Role</th>
          <th class="text-left px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium hidden sm:table-cell">Info</th>
          <% if (user.role === 'superadmin' || user.role === 'admin') { %>
          <th class="text-center px-3 sm:px-6 py-3 text-gray-500 dark:text-gray-400 font-medium">Actions</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (user.role === 'masteragent') { %>
          <!-- Manager view: simple flat list of users only -->
          <% users.filter(u => u.role === 'subagent').forEach(u => { %>
            <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-3 sm:px-6 py-3 font-medium"><%= u.username %></td>
              <td class="px-3 sm:px-6 py-3">
                <span class="px-2.5 py-1 rounded-lg text-xs font-medium capitalize
                  <% if (u.role === 'masteragent') { %>bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300
                  <% } else { %>bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400<% } %>">
                  <%= roleLabel(u.role) %>
                </span>
              </td>
              <td class="px-3 sm:px-6 py-3 text-gray-400 text-xs hidden sm:table-cell">-</td>
            </tr>
          <% }) %>

        <% } else { %>
          <!-- Admin/Superadmin view: nested stacked table -->
          <!-- Admin/Superadmin rows -->
          <% admins.forEach(u => { %>
            <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-3 sm:px-6 py-3 font-medium"><%= u.username %></td>
              <td class="px-3 sm:px-6 py-3">
                <span class="px-2.5 py-1 rounded-lg text-xs font-medium capitalize
                  <% if (u.role === 'superadmin') { %>bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300
                  <% } else { %>bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300<% } %>">
                  <%= u.role %>
                </span>
              </td>
              <td class="px-3 sm:px-6 py-3 text-gray-400 text-xs hidden sm:table-cell">-</td>
              <td class="px-3 sm:px-6 py-3 text-center">
                <div class="flex items-center justify-center gap-1.5 flex-wrap">
                <% if (u.id !== user.id) { %>
                <button type="button" onclick="openEditModal('<%= u.id %>', '<%= u.username %>', '<%= u.role %>', '')"
                  class="px-2.5 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-lg text-xs font-medium hover:bg-amber-200 dark:hover:bg-amber-900/50 transition-colors">Edit</button>
                <% if (user.role === 'superadmin') { %>
                <form method="POST" action="/dashboard/users/impersonate/<%= u.id %>" class="inline">
                  <button type="submit" class="px-2.5 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">Impersonate</button>
                </form>
                <% } %>
                <form method="POST" action="/dashboard/users/delete/<%= u.id %>" class="inline" onsubmit="return confirm('Delete this user?')">
                  <button type="submit" class="px-2.5 py-1 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-lg text-xs font-medium hover:bg-red-200 dark:hover:bg-red-900/50 transition-colors">Delete</button>
                </form>
                <% } %>
                </div>
              </td>
            </tr>
          <% }) %>

          <!-- Manager rows (collapsible) -->
          <% masters.forEach(ma => {
            const maSubs = subs.filter(s => s.parent_id === ma.id);
          %>
            <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors cursor-pointer ma-row" data-ma-id="<%= ma.id %>" onclick="toggleSubagents('<%= ma.id %>')">
              <td class="px-3 sm:px-6 py-3 font-medium">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400 transition-transform duration-200 ma-chevron" data-ma-id="<%= ma.id %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  <%= ma.username %>
                </div>
              </td>
              <td class="px-3 sm:px-6 py-3">
                <span class="px-2.5 py-1 rounded-lg text-xs font-medium capitalize bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300">Manager</span>
              </td>
              <td class="px-3 sm:px-6 py-3 text-gray-400 text-xs hidden sm:table-cell">
                <span class="px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 text-xs font-medium"><%= maSubs.length %> user<%= maSubs.length !== 1 ? 's' : '' %></span>
              </td>
              <td class="px-3 sm:px-6 py-3 text-center">
                <div class="flex items-center justify-center gap-1.5 flex-wrap">
                <% if (ma.id !== user.id) { %>
                <button type="button" onclick="event.stopPropagation(); openEditModal('<%= ma.id %>', '<%= ma.username %>', '<%= ma.role %>', '')"
                  class="px-2.5 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-lg text-xs font-medium hover:bg-amber-200 dark:hover:bg-amber-900/50 transition-colors">Edit</button>
                <% if (user.role === 'superadmin') { %>
                <form method="POST" action="/dashboard/users/impersonate/<%= ma.id %>" class="inline" onclick="event.stopPropagation()">
                  <button type="submit" class="px-2.5 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">Impersonate</button>
                </form>
                <% } %>
                <form method="POST" action="/dashboard/users/delete/<%= ma.id %>" class="inline" onsubmit="return confirm('Delete this user?')" onclick="event.stopPropagation()">
                  <button type="submit" class="px-2.5 py-1 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-lg text-xs font-medium hover:bg-red-200 dark:hover:bg-red-900/50 transition-colors">Delete</button>
                </form>
                <% } %>
                </div>
              </td>
            </tr>

            <!-- User rows (hidden by default) -->
            <% maSubs.forEach(sa => { %>
            <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors sa-row hidden bg-gray-50/50 dark:bg-gray-800/30" data-parent-ma="<%= ma.id %>">
              <td class="px-3 sm:px-6 py-3 font-medium pl-10 sm:pl-14">
                <div class="flex items-center gap-2">
                  <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-gray-600"></div>
                  <%= sa.username %>
                </div>
              </td>
              <td class="px-3 sm:px-6 py-3">
                <span class="px-2.5 py-1 rounded-lg text-xs font-medium capitalize bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">User</span>
              </td>
              <td class="px-3 sm:px-6 py-3 text-gray-400 text-xs hidden sm:table-cell"><%= ma.username %></td>
              <td class="px-3 sm:px-6 py-3 text-center">
                <div class="flex items-center justify-center gap-1.5 flex-wrap">
                <button type="button" onclick="openEditModal('<%= sa.id %>', '<%= sa.username %>', '<%= sa.role %>', '<%= sa.parent_id || '' %>')"
                  class="px-2.5 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-lg text-xs font-medium hover:bg-amber-200 dark:hover:bg-amber-900/50 transition-colors">Edit</button>
                <% if (user.role === 'superadmin') { %>
                <form method="POST" action="/dashboard/users/impersonate/<%= sa.id %>" class="inline">
                  <button type="submit" class="px-2.5 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg text-xs font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">Impersonate</button>
                </form>
                <% } %>
                <form method="POST" action="/dashboard/users/delete/<%= sa.id %>" class="inline" onsubmit="return confirm('Delete this user?')">
                  <button type="submit" class="px-2.5 py-1 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-lg text-xs font-medium hover:bg-red-200 dark:hover:bg-red-900/50 transition-colors">Delete</button>
                </form>
                </div>
              </td>
            </tr>
            <% }) %>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Create User Modal -->
<% if (creatableRoles.length > 0) { %>
<div id="createUserModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="document.getElementById('createUserModal').classList.add('hidden')"></div>
  <div class="relative bg-white dark:bg-gray-900 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-800 w-full max-w-md mx-4 p-6 transform transition-all">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-base font-semibold">Create New User</h3>
      <button onclick="document.getElementById('createUserModal').classList.add('hidden')"
        class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <form method="POST" action="/dashboard/users" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username</label>
        <input type="text" name="username" required
          class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
        <input type="password" name="password" required
          class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Role</label>
        <select name="role" id="roleSelect" onchange="handleRoleChange()"
          class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
          <% creatableRoles.forEach(r => { %>
            <option value="<%= r %>"><%= roleLabel(r) %></option>
          <% }) %>
        </select>
      </div>

      <% if (user.role === 'masteragent') { %>
        <input type="hidden" name="parent_id" value="<%= user.id %>">
      <% } else { %>
        <div id="parentField">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Manager</label>
          <div class="relative">
            <input type="hidden" name="parent_id" id="parentIdHidden">
            <input type="text" id="maSearch" autocomplete="off" placeholder="Search manager..."
              class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
            <div id="maDropdown" class="hidden absolute z-10 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-48 overflow-y-auto">
              <% if (typeof masterAgents !== 'undefined') { masterAgents.forEach(ma => { %>
                <div class="ma-option px-4 py-2.5 text-sm hover:bg-primary-50 dark:hover:bg-primary-900/30 cursor-pointer transition-colors"
                  data-id="<%= ma.id %>" data-username="<%= ma.username %>" data-ref="<%= ma.referral_code || '' %>">
                  <span class="font-medium"><%= ma.username %></span>
                  <% if (ma.referral_code) { %>
                    <span class="text-xs text-gray-400 ml-2"><%= ma.referral_code %></span>
                  <% } %>
                </div>
              <% })} %>
            </div>
          </div>
        </div>
      <% } %>

      <button type="submit"
        class="w-full bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 rounded-xl text-sm transition-colors">
        Create User
      </button>
    </form>
  </div>
</div>
<% } %>

<!-- Edit User Modal -->
<% if (user.role === 'superadmin' || user.role === 'admin') { %>
<div id="editUserModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="document.getElementById('editUserModal').classList.add('hidden')"></div>
  <div class="relative bg-white dark:bg-gray-900 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-800 w-full max-w-md mx-4 p-6 transform transition-all">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-base font-semibold">Edit User</h3>
      <button onclick="document.getElementById('editUserModal').classList.add('hidden')"
        class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <form id="editUserForm" method="POST" action="" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username</label>
        <input type="text" name="username" id="editUsername" required
          class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password <span class="text-xs text-gray-400">(leave blank to keep current)</span></label>
        <input type="password" name="password" id="editPassword"
          class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500"
          placeholder="Enter new password">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Role</label>
        <select name="role" id="editRoleSelect" onchange="handleEditRoleChange()"
          class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
          <% creatableRoles.forEach(r => { %>
            <option value="<%= r %>"><%= r.charAt(0).toUpperCase() + r.slice(1) %></option>
          <% }) %>
        </select>
      </div>

      <div id="editParentField">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Manager</label>
        <div class="relative">
          <input type="hidden" name="parent_id" id="editParentIdHidden">
          <input type="text" id="editMaSearch" autocomplete="off" placeholder="Search manager..."
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm outline-none focus:ring-2 focus:ring-primary-500">
          <div id="editMaDropdown" class="hidden absolute z-10 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-48 overflow-y-auto">
            <% if (typeof masterAgents !== 'undefined') { masterAgents.forEach(ma => { %>
              <div class="edit-ma-option px-4 py-2.5 text-sm hover:bg-primary-50 dark:hover:bg-primary-900/30 cursor-pointer transition-colors"
                data-id="<%= ma.id %>" data-username="<%= ma.username %>" data-ref="<%= ma.referral_code || '' %>">
                <span class="font-medium"><%= ma.username %></span>
                <% if (ma.referral_code) { %>
                  <span class="text-xs text-gray-400 ml-2"><%= ma.referral_code %></span>
                <% } %>
              </div>
            <% })} %>
          </div>
        </div>
      </div>

      <button type="submit"
        class="w-full bg-amber-600 hover:bg-amber-700 text-white font-medium py-2.5 rounded-xl text-sm transition-colors">
        Update User
      </button>
    </form>
  </div>
</div>
<% } %>

<script>
// --- Toggle subagents ---
function toggleSubagents(maId) {
  const rows = document.querySelectorAll('.sa-row[data-parent-ma="' + maId + '"]');
  const chevron = document.querySelector('.ma-chevron[data-ma-id="' + maId + '"]');
  const isHidden = rows[0]?.classList.contains('hidden');
  rows.forEach(r => r.classList.toggle('hidden', !isHidden));
  if (chevron) chevron.style.transform = isHidden ? 'rotate(90deg)' : '';
}

// --- Create Modal ---
function handleRoleChange() {
  const role = document.getElementById('roleSelect')?.value;
  const parentField = document.getElementById('parentField');
  if (parentField) {
    parentField.style.display = role === 'subagent' ? 'block' : 'none';
    if (role !== 'subagent') {
      document.getElementById('parentIdHidden').value = '';
      document.getElementById('maSearch').value = '';
    }
  }
}
document.addEventListener('DOMContentLoaded', handleRoleChange);

// Searchable master agent dropdown (Create)
(function() {
  const search = document.getElementById('maSearch');
  const dropdown = document.getElementById('maDropdown');
  const hidden = document.getElementById('parentIdHidden');
  if (!search || !dropdown) return;

  const options = dropdown.querySelectorAll('.ma-option');

  search.addEventListener('focus', function() {
    dropdown.classList.remove('hidden');
    filterOptions();
  });

  search.addEventListener('input', function() {
    dropdown.classList.remove('hidden');
    hidden.value = '';
    filterOptions();
  });

  function filterOptions() {
    const q = search.value.toLowerCase();
    options.forEach(opt => {
      const name = (opt.dataset.username || '').toLowerCase();
      const ref = (opt.dataset.ref || '').toLowerCase();
      opt.style.display = (name.includes(q) || ref.includes(q)) ? '' : 'none';
    });
  }

  options.forEach(opt => {
    opt.addEventListener('click', function() {
      hidden.value = this.dataset.id;
      search.value = this.dataset.username;
      dropdown.classList.add('hidden');
    });
  });

  document.addEventListener('click', function(e) {
    if (!search.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });
})();

// --- Edit Modal ---
function handleEditRoleChange() {
  const role = document.getElementById('editRoleSelect')?.value;
  const parentField = document.getElementById('editParentField');
  if (parentField) {
    parentField.style.display = role === 'subagent' ? 'block' : 'none';
    if (role !== 'subagent') {
      document.getElementById('editParentIdHidden').value = '';
      document.getElementById('editMaSearch').value = '';
    }
  }
}

function openEditModal(id, username, role, parentId) {
  document.getElementById('editUserForm').action = '/dashboard/users/edit/' + id;
  document.getElementById('editUsername').value = username;
  document.getElementById('editPassword').value = '';

  const roleSelect = document.getElementById('editRoleSelect');
  if (roleSelect) roleSelect.value = role;

  document.getElementById('editParentIdHidden').value = parentId;
  const editSearch = document.getElementById('editMaSearch');
  if (parentId && editSearch) {
    const opt = document.querySelector('.edit-ma-option[data-id="' + parentId + '"]');
    editSearch.value = opt ? opt.dataset.username : '';
  } else if (editSearch) {
    editSearch.value = '';
  }

  handleEditRoleChange();
  document.getElementById('editUserModal').classList.remove('hidden');
}

// Searchable master agent dropdown (Edit)
(function() {
  const search = document.getElementById('editMaSearch');
  const dropdown = document.getElementById('editMaDropdown');
  const hidden = document.getElementById('editParentIdHidden');
  if (!search || !dropdown) return;

  const options = dropdown.querySelectorAll('.edit-ma-option');

  search.addEventListener('focus', function() {
    dropdown.classList.remove('hidden');
    filterOptions();
  });

  search.addEventListener('input', function() {
    dropdown.classList.remove('hidden');
    hidden.value = '';
    filterOptions();
  });

  function filterOptions() {
    const q = search.value.toLowerCase();
    options.forEach(opt => {
      const name = (opt.dataset.username || '').toLowerCase();
      const ref = (opt.dataset.ref || '').toLowerCase();
      opt.style.display = (name.includes(q) || ref.includes(q)) ? '' : 'none';
    });
  }

  options.forEach(opt => {
    opt.addEventListener('click', function() {
      hidden.value = this.dataset.id;
      search.value = this.dataset.username;
      dropdown.classList.add('hidden');
    });
  });

  document.addEventListener('click', function(e) {
    if (!search.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });
})();

// Close modals on Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.getElementById('createUserModal')?.classList.add('hidden');
    document.getElementById('editUserModal')?.classList.add('hidden');
  }
});
</script>
