<% if (typeof user !== 'undefined' && user && typeof locals.originalUser !== 'undefined' && locals.originalUser) { %>
<div class="bg-amber-500 text-white text-center text-sm py-2 px-4 flex items-center justify-center gap-3">
  <span>⚠️ Impersonating <strong><%= user.name %></strong> (<%= user.role %>)</span>
  <a href="/dashboard/users/stop-impersonate" class="bg-white text-amber-600 px-3 py-1 rounded-lg text-xs font-semibold hover:bg-amber-50 transition-colors">Stop Impersonating</a>
</div>
<% } %>
<header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 px-4 sm:px-6 py-4 flex items-center justify-between gap-3">
  <div class="flex items-center gap-3 min-w-0">
    <!-- Mobile hamburger -->
    <button onclick="toggleSidebar()" class="lg:hidden p-2 -ml-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <h2 class="text-lg font-semibold truncate"><%= title %></h2>
    <% if (typeof caseInfoBadges !== 'undefined' && caseInfoBadges) { %>
      <div class="hidden sm:flex items-center gap-1.5 ml-2">
        <% if (caseInfoBadges.product) { %>
          <span class="px-2 py-0.5 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-[11px] font-medium"><%= caseInfoBadges.product %></span>
        <% } %>
        <% if (caseInfoBadges.masteragent) { %>
          <span class="px-2 py-0.5 rounded-lg bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 text-[11px] font-medium">MA: <%= caseInfoBadges.masteragent %></span>
        <% } %>
        <% if (caseInfoBadges.subagent) { %>
          <span class="px-2 py-0.5 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 text-[11px] font-medium">SA: <%= caseInfoBadges.subagent %></span>
        <% } %>
      </div>
    <% } %>
  </div>
  <div class="flex items-center gap-4">
    <% if (typeof user !== 'undefined' && user && (user.role === 'superadmin' || user.role === 'admin')) { %>
    <!-- Notification Bell -->
    <div class="relative" id="notifBellWrap">
      <button onclick="toggleNotifDropdown()" class="relative p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        <span id="notifBadge" class="hidden absolute -top-0.5 -right-0.5 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
      </button>
      <!-- Dropdown -->
      <div id="notifDropdown" class="hidden absolute right-0 top-full mt-2 w-80 bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 z-50 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-800 flex items-center justify-between">
          <h4 class="text-sm font-semibold">Notifications</h4>
          <button onclick="clearAllNotifs()" class="text-[10px] text-primary-600 dark:text-primary-400 hover:underline font-medium">Mark all read</button>
        </div>
        <div id="notifList" class="max-h-80 overflow-y-auto divide-y divide-gray-100 dark:divide-gray-800">
          <div class="px-4 py-6 text-center text-gray-400 text-xs">No notifications</div>
        </div>
      </div>
    </div>
    <% } %>
    <button onclick="toggleDark()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
      <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
    </button>
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center">
        <span class="text-sm font-semibold text-primary-700 dark:text-primary-300"><%= user.name.charAt(0).toUpperCase() %></span>
      </div>
      <p class="text-sm font-medium hidden sm:block"><%= user.name %></p>
    </div>
    <% } %>
  </div>
</header>

<script>
// Notification system
function getNotifs() { try { return JSON.parse(localStorage.getItem('appNotifs') || '[]'); } catch { return []; } }
function saveNotifs(list) { localStorage.setItem('appNotifs', JSON.stringify(list.slice(0, 50))); }

function addNotif(data) {
  const list = getNotifs();
  // Avoid exact duplicate by caseId+timestamp within 2s
  const isDup = list.some(n => n.caseId === data.caseId && Math.abs(n.timestamp - data.timestamp) < 2000);
  if (isDup) return;
  list.unshift({
    id: Date.now() + Math.random(),
    type: data.type,
    caseId: data.caseId,
    applicantName: data.applicantName || data.applicant_name || 'Unknown',
    message: data.type === 'CASE_MODIFIED' ? 'Dokumen dikemaskini' : data.type === 'NEW_CASE' ? 'Permohonan baru' : 'Kes diambil',
    timestamp: data.timestamp || Date.now(),
    read: false
  });
  saveNotifs(list);
  renderNotifs();
}

function renderNotifs() {
  const list = getNotifs();
  const unread = list.filter(n => !n.read).length;
  const badge = document.getElementById('notifBadge');
  if (badge) {
    badge.textContent = unread;
    badge.classList.toggle('hidden', unread === 0);
  }
  const container = document.getElementById('notifList');
  if (!container) return;
  if (list.length === 0) {
    container.innerHTML = '<div class="px-4 py-6 text-center text-gray-400 text-xs">No notifications</div>';
    return;
  }
  container.innerHTML = list.map(n => {
    const icon = n.type === 'CASE_MODIFIED' ? '📝' : n.type === 'NEW_CASE' ? '🆕' : '✅';
    const bg = n.read ? '' : 'bg-blue-50/50 dark:bg-blue-900/10';
    const ago = timeAgo(n.timestamp);
    return `<a href="/dashboard/cases/${n.caseId}" onclick="markRead('${n.id}')" class="block px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors ${bg}">
      <div class="flex items-start gap-2.5">
        <span class="text-base mt-0.5">${icon}</span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium truncate ${n.read ? 'text-gray-500 dark:text-gray-400' : ''}">${n.applicantName}</p>
          <p class="text-[11px] text-gray-500 dark:text-gray-400">${n.message}</p>
          <p class="text-[10px] text-gray-400 mt-0.5">${ago}</p>
        </div>
        ${!n.read ? '<span class="w-2 h-2 rounded-full bg-blue-500 mt-1.5 shrink-0"></span>' : ''}
      </div>
    </a>`;
  }).join('');
}

function markRead(id) {
  const list = getNotifs();
  const n = list.find(x => String(x.id) === String(id));
  if (n) n.read = true;
  saveNotifs(list);
}

function clearAllNotifs() {
  const list = getNotifs();
  list.forEach(n => n.read = true);
  saveNotifs(list);
  renderNotifs();
}

function toggleNotifDropdown() {
  const dd = document.getElementById('notifDropdown');
  dd.classList.toggle('hidden');
}

// Close dropdown on outside click
document.addEventListener('click', function(e) {
  const wrap = document.getElementById('notifBellWrap');
  const dd = document.getElementById('notifDropdown');
  if (wrap && dd && !wrap.contains(e.target)) dd.classList.add('hidden');
});

function timeAgo(ts) {
  const s = Math.floor((Date.now() - ts) / 1000);
  if (s < 60) return 'Baru sahaja';
  if (s < 3600) return Math.floor(s/60) + 'm ago';
  if (s < 86400) return Math.floor(s/3600) + 'h ago';
  return Math.floor(s/86400) + 'd ago';
}

// Expose for WS handlers
window._addNotif = addNotif;
// Render on load
renderNotifs();
</script>
